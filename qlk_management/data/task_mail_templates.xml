<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="mail_template_qlk_task_assignment" model="mail.template">
        <field name="name">QLK Task Assignment</field>
        <field name="model_id" ref="qlk_task_management.model_qlk_task"/>
        <field name="subject">New Task Assigned: {{ object.display_name }}</field>
        <field name="email_from">{{ (object.create_uid.email_formatted or user.email_formatted or 'no-reply@qlk.local') }}</field>
        <field name="body_html" type="html">
            <div>
                <p>Dear <t t-out="object.assigned_user_id.name or object.employee_id.name"/>,</p>
                <p>A task has been assigned to you.</p>
                <ul>
                    <li><strong>Task:</strong> <t t-out="object.display_name"/></li>
                    <li><strong>Description:</strong> <t t-out="object.description or '-'"/></li>
                    <li><strong>Priority:</strong> <t t-out="dict(object._fields['priority'].selection).get(object.priority, object.priority or '-')"/></li>
                    <li><strong>Project:</strong> <t t-out="object.project_id.display_name if object.project_id else '-'"/></li>
                    <li><strong>Receive Date:</strong> <t t-out="format_datetime(object.receive_date) if object.receive_date else '-'"/></li>
                    <li><strong>Delivery Date:</strong> <t t-out="format_datetime(object.delivery_date) if object.delivery_date else '-'"/></li>
                    <li><strong>Required Hours:</strong> <t t-out="object.required_hours or 0.0"/></li>
                    <li><strong>Created By:</strong> <t t-out="object.create_uid.name"/></li>
                </ul>
                <p>
                    <a t-attf-href="{{ object.get_base_url() }}/web#id={{ object.id }}&amp;model=qlk.task&amp;view_type=form"
                       style="display:inline-block;padding:10px 14px;background:#0f5ca8;color:#ffffff;text-decoration:none;border-radius:6px;">
                        Open Task
                    </a>
                </p>
                <p>Regards,<br/>QLK</p>
            </div>
        </field>
        <field name="auto_delete" eval="True"/>
    </record>

    <record id="mail_template_qlk_task_completion" model="mail.template">
        <field name="name">QLK Task Completion</field>
        <field name="model_id" ref="qlk_task_management.model_qlk_task"/>
        <field name="subject">Task Completed: {{ object.display_name }}</field>
        <field name="email_from">{{ (object.completed_by.email_formatted or user.email_formatted or 'no-reply@qlk.local') }}</field>
        <field name="body_html" type="html">
            <div>
                <p>Task has been completed by <t t-out="object.completed_by.name if object.completed_by else user.name"/>.</p>
                <ul>
                    <li><strong>Task:</strong> <t t-out="object.display_name"/></li>
                    <li><strong>Description:</strong> <t t-out="object.description or '-'"/></li>
                    <li><strong>Priority:</strong> <t t-out="dict(object._fields['priority'].selection).get(object.priority, object.priority or '-')"/></li>
                    <li><strong>Deadline:</strong> <t t-out="format_datetime(object.delivery_date) if object.delivery_date else (object.date_finished or '-')"/></li>
                    <li><strong>Completed On:</strong> <t t-out="format_datetime(object.completed_date) if object.completed_date else '-'"/></li>
                    <li><strong>Created By:</strong> <t t-out="object.create_uid.name"/></li>
                </ul>
                <p>
                    <a t-attf-href="{{ object.get_base_url() }}/web#id={{ object.id }}&amp;model=qlk.task&amp;view_type=form"
                       style="display:inline-block;padding:10px 14px;background:#0f5ca8;color:#ffffff;text-decoration:none;border-radius:6px;">
                        Review Completion
                    </a>
                </p>
                <p>Regards,<br/>QLK</p>
            </div>
        </field>
        <field name="auto_delete" eval="True"/>
    </record>

    <record id="mail_template_project_task_assignment" model="mail.template">
        <field name="name">Project Task Assignment</field>
        <field name="model_id" ref="project.model_project_task"/>
        <field name="subject">New Project Task Assigned: {{ object.display_name }}</field>
        <field name="email_from">{{ (object.create_uid.email_formatted or user.email_formatted or 'no-reply@qlk.local') }}</field>
        <field name="body_html" type="html">
            <div>
                <p>Dear User,</p>
                <p>A project task has been assigned to you.</p>
                <ul>
                    <li><strong>Task Name:</strong> <t t-out="object.display_name"/></li>
                    <li><strong>Project Name:</strong> <t t-out="object.project_id.display_name if object.project_id else '-'"/></li>
                    <li><strong>Task Description:</strong> <t t-out="object.description or '-'"/></li>
                    <li><strong>Assigned By:</strong> <t t-out="object.write_uid.name or object.create_uid.name"/></li>
                    <li><strong>Priority:</strong> <t t-out="dict(object._fields['priority'].selection).get(object.priority, object.priority or '-')"/></li>
                    <li><strong>Planned Hours:</strong> <t t-out="object.allocated_hours or 0.0"/></li>
                </ul>
                <p>
                    <a t-attf-href="{{ object.get_base_url() }}/web#id={{ object.id }}&amp;model=project.task&amp;view_type=form"
                       style="display:inline-block;padding:10px 14px;background:#0f5ca8;color:#ffffff;text-decoration:none;border-radius:6px;">
                        Open Task
                    </a>
                </p>
                <p>Regards,<br/>QLK</p>
            </div>
        </field>
        <field name="auto_delete" eval="True"/>
    </record>

