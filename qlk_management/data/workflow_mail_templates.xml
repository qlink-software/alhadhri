<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="mail_template_client_file_created_poa_required" model="mail.template">
        <field name="name">Client File Created - POA Preparation</field>
        <field name="model_id" ref="model_qlk_client_file"/>
        <field name="subject">New Client File Created – POA Preparation Required</field>
        <field name="email_from">{{ (user.email_formatted or object.company_id.email or 'no-reply@qlk.local') }}</field>
        <field name="email_to">mp.office@alhadhrilawfirm.com</field>
        <field name="body_html" type="html">
            <div style="font-family:Arial, sans-serif;font-size:14px;color:#222;">
                <p>Dear MP Office,</p>
                <p>A new client file has been created and requires POA preparation.</p>
                <p><strong>Client Details:</strong></p>
                <ul>
                    <li><strong>Client Name:</strong> <t t-out="object.partner_id.name or '-'"/></li>
                    <li><strong>File Number:</strong> <t t-out="object.name or '-'"/></li>
                    <li><strong>Responsible Lawyer:</strong> <t t-out="object.qlk_responsible_lawyer_name()"/></li>
                </ul>
                <p>
                    <strong>Open Record:</strong><br/>
                    <a t-att-href="object.qlk_record_url()" style="color:#0f5ca8;text-decoration:none;">
                        <t t-out="object.qlk_record_url()"/>
                    </a>
                </p>
                <p>Regards,<br/>QLK LawPro System</p>
            </div>
        </field>
        <field name="auto_delete" eval="False"/>
    </record>

