<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Professional email template used by qlk.project to notify MP Office that
        a POA request should be forwarded/assigned. The target email is fixed,
        while the body is populated from the project and its client.
    -->
    <record id="mail_template_project_poa_mp" model="mail.template">
        <field name="name">POA Request to MP</field>
        <field name="model_id" ref="model_qlk_project"/>
        <field name="subject">POA Request - {{ object.client_id.name or object.name }}</field>
        <field name="email_to">mp.office@alhadhrilawfirm.com</field>
        <field name="email_from">{{ user.email_formatted or user.company_id.partner_id.email_formatted or '' }}</field>
        <field name="body_html" type="html">
            <div>
                <p>Dear MP Office,</p>

                <p>Please proceed with forwarding/assigning the Power of Attorney (POA) request.</p>

                <p><strong>Client Details:</strong></p>
                <ul>
                    <li><strong>Client Name:</strong> {{ object.client_id.name or '' }}</li>
                    <li><strong>Client Code:</strong> {{ object.client_code or object.client_id.code or '' }}</li>
                    <li><strong>Phone:</strong> {{ object.client_id.phone or object.client_id.mobile or '' }}</li>
                    <li><strong>Email:</strong> {{ object.client_id.email or '' }}</li>
                </ul>

                <p><strong>Project / Case Details:</strong></p>
                <ul>
                    <li><strong>Reference:</strong> {{ object.code or object.reference or object.name or '' }}</li>
                    <li><strong>Assigned Lawyer:</strong> {{ object.lawyer_id.name or '' }}</li>
                </ul>

                <p>Kindly take the necessary action.</p>

                <p>
                    Best Regards,<br/>
                    {{ user.name }}
                </p>
            </div>
        </field>
        <field name="auto_delete" eval="True"/>
    </record>
</odoo>
