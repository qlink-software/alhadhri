<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_qlk_poa_upload_wizard_form" model="ir.ui.view">
        <field name="name">qlk.poa.upload.wizard.form</field>
        <field name="model">qlk.poa.upload.wizard</field>
        <field name="arch" type="xml">
            <form string="Upload POA">
                <sheet>
                    <group>
                        <field name="client_file_id"/>
                        <field name="poa_received_date"/>
                        <field name="poa_expiry_date"/>
                    </group>
                    <group>
                        <field name="attachment_ids" widget="many2many_binary" nolabel="1"/>
                        <field name="poa_notes" placeholder="Notes / ملاحظات"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_upload" type="object" string="Upload" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
