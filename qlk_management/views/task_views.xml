<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_qlk_task_search_project_inherit" model="ir.ui.view">
            <field name="name">qlk.task.search.project.inherit</field>
            <field name="model">qlk.task</field>
            <field name="inherit_id" ref="qlk_task_management.view_qlk_task_search"/>
            <field name="arch" type="xml">
                <xpath expr="//search/filter[@name='filter_waiting']" position="after">
                    <filter name="filter_corporate" string="Corporate" domain="[('department', '=', 'corporate')]"/>
                    <filter name="filter_litigation" string="Litigation" domain="[('department', '=', 'litigation')]"/>
                    <filter name="filter_arbitration" string="Arbitration" domain="[('department', '=', 'arbitration')]"/>
                </xpath>
                <xpath expr="//search/group" position="inside">
                    <filter name="group_employee" string="Lawyer" context="{'group_by': 'assigned_user_id'}"/>
                    <filter name="group_task_date" string="Date" context="{'group_by': 'date_start'}"/>
                </xpath>
            </field>
        </record>

        <record id="view_qlk_task_list_priority_inherit" model="ir.ui.view">
            <field name="name">qlk.task.list.priority.inherit</field>
            <field name="model">qlk.task</field>
            <field name="inherit_id" ref="qlk_task_management.view_qlk_task_list"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='approval_state']" position="after">
                    <field name="priority" widget="badge"/>
                </xpath>
            </field>
        </record>

        <record id="view_qlk_task_form_assignment_details" model="ir.ui.view">
            <field name="name">qlk.task.form.assignment.details</field>
            <field name="model">qlk.task</field>
            <field name="inherit_id" ref="qlk_task_management.view_qlk_task_form"/>
            <field name="arch" type="xml">
                <xpath expr="//header/button[@name='action_submit_for_approval']" position="before">
                    <button name="action_mark_completed"
                            type="object"
                            string="Mark as Completed"
                            class="btn-success"
                            invisible="not can_mark_completed"/>
                    <button name="action_review_completion"
                            type="object"
                            string="Completion Reviewed"
                            class="btn-primary"
                            invisible="not can_review_completion"/>
                </xpath>
                <xpath expr="//header/field[@name='approval_state']" position="replace"/>
                <xpath expr="//div[@name='button_box']" position="after">
                    <group string="Task Status / حالة المهمة">
                        <field name="approval_state" widget="statusbar" statusbar_visible="draft,waiting,approved,rejected"/>
                        <field name="completion_state" widget="statusbar" statusbar_visible="draft,in_progress,completed"/>
                        <field name="can_mark_completed" invisible="1"/>
                        <field name="can_review_completion" invisible="1"/>
                    </group>
                </xpath>
                <xpath expr="//group[field[@name='name']]" position="replace">
                    <group>
                        <group string="Task Details / بيانات المهمة">
                            <field name="name"/>
                            <field name="project_id"/>
                            <field name="client_id" readonly="1"/>
                            <field name="employee_id"/>
                            <field name="approval_state" readonly="1" widget="badge"/>
                        </group>
                        <group string="Schedule &amp; Hours / المواعيد والساعات">
                            <field name="receive_date"/>
                            <field name="delivery_date"/>
                            <field name="required_hours" required="1" widget="qlk_float_time_hms" options="{'displaySeconds': True}"/>
                            <field name="hours_spent" widget="qlk_float_time_hms" options="{'displaySeconds': True}"/>
                            <field name="planned_hours" readonly="1" widget="float_time"/>
                            <field name="consumed_hours" readonly="1" widget="float_time"/>
                            <field name="remaining_hours" readonly="1" widget="float_time" decoration-danger="remaining_hours &lt; 0"/>
                            <field name="date_start"/>
                            <field name="date_finished"/>
                            <field name="completed_by" readonly="1"/>
                            <field name="completed_date" readonly="1"/>
                            <field name="completion_reviewed_by" readonly="1"/>
                            <field name="completion_reviewed_date" readonly="1"/>
                        </group>
                        <group string="Classification / التصنيف">
                            <field name="priority"/>
                            <field name="department"/>
                            <field name="litigation_phase" invisible="department != 'litigation'"/>
                            <field name="case_id"
                                   context="{'default_department': 'litigation'}"
                                   required="department == 'litigation'"
                                   invisible="department != 'litigation'"/>
                            <field name="pre_litigation_id" invisible="department != 'pre_litigation'"/>
                            <field name="corporate_case_id" invisible="department != 'corporate'"/>
                            <field name="arbitration_case_id" invisible="department != 'arbitration'"/>
                            <field name="reviewer_id"/>
                        </group>
                    </group>
                </xpath>
                <xpath expr="//group[field[@name='description']]" position="replace">
                    <notebook>
                        <page string="Description / الوصف">
                            <field name="description" nolabel="1"/>
                        </page>
                        <page string="Attachments / المرفقات">
                            <field name="attachment_ids" nolabel="1" context="{'default_res_model': 'qlk.task', 'default_res_id': id}">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="datas" string="Preview / Download" filename="name" widget="binary"/>
                                    <field name="create_date" string="Upload Date" readonly="1"/>
                                    <field name="create_uid" string="Uploaded By" readonly="1"/>
                                    <field name="mimetype" readonly="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </xpath>
                <xpath expr="//group[field[@name='approval_comment']]" position="replace">
                    <group string="Approval Notes / ملاحظات الاعتماد">
                        <field name="approval_comment" readonly="approval_state == 'approved'"/>
                    </group>
                </xpath>
            </field>
        </record>

        <record id="view_qlk_task_kanban_professional" model="ir.ui.view">
            <field name="name">qlk.task.kanban.professional</field>
            <field name="model">qlk.task</field>
            <field name="arch" type="xml">
                <kanban default_group_by="approval_state" class="o_kanban_small_column">
                    <field name="name"/>
                    <field name="project_id"/>
                    <field name="employee_id"/>
                    <field name="assigned_user_id"/>
                    <field name="receive_date"/>
                    <field name="delivery_date"/>
                    <field name="required_hours"/>
                    <field name="approval_state"/>
                    <field name="department"/>
                    <field name="priority"/>
                    <templates>
                        <t t-name="card" t-attf-class="qlk_task_card qlk_task_state_#{record.approval_state.raw_value or 'draft'}">
                                <div class="d-flex justify-content-between align-items-start gap-2">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                    <span t-attf-class="badge rounded-pill qlk_task_badge qlk_task_badge_#{record.approval_state.raw_value or 'draft'}">
                                        <field name="approval_state"/>
                                    </span>
                                </div>
                                <div class="text-muted mt-1" t-if="record.project_id.raw_value">
                                    <i class="fa fa-folder-o me-1"/> <field name="project_id"/>
                                </div>
                                <div class="qlk_task_meta mt-3">
                                    <span><i class="fa fa-inbox me-1"/> <field name="receive_date" widget="datetime"/></span>
                                    <span><i class="fa fa-paper-plane-o me-1"/> <field name="delivery_date" widget="datetime"/></span>
                                    <span class="qlk_task_hours"><i class="fa fa-clock-o me-1"/> <field name="required_hours" widget="qlk_float_time_hms" options="{'displaySeconds': True}"/></span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center mt-3">
                                    <span class="text-muted"><i class="fa fa-user-o me-1"/> <field name="employee_id"/></span>
                                    <span>
                                        <span class="badge text-bg-light"><field name="priority"/></span>
                                        <span class="badge text-bg-light"><field name="department"/></span>
                                    </span>
                                </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="qlk_task_management.action_qlk_task_all" model="ir.actions.act_window">
            <field name="view_mode">kanban,list,form</field>
        </record>
        <record id="qlk_task_management.action_qlk_task_litigation" model="ir.actions.act_window">
            <field name="view_mode">kanban,list,form</field>
        </record>
        <record id="qlk_task_management.action_qlk_task_corporate" model="ir.actions.act_window">
            <field name="view_mode">kanban,list,form</field>
        </record>
        <record id="qlk_task_management.action_qlk_task_management" model="ir.actions.act_window">
            <field name="view_mode">kanban,list,form</field>
        </record>

    </data>
</odoo>
