<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="task_view_form" model="ir.ui.view">
        <field name="name">task.view.form</field>
        <field name="model">task</field>
        <field name="arch" type="xml">
            <form string="">
                <header>
                    <button string="To Confirm" name="confirm_acrion" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button string="Done" name="done_acrion" type="object" class="oe_highlight" invisible="state != 'confrim'"/>
                    <button string="Reject" name="reject_acrion" type="object" invisible="state in ['draft','reject']"/>
                    <button string="Cancel" name="cancel_acrion" type="object" invisible="state in ['draft','cancel']"/>
                </header>
                <sheet>
                    <div>
                        <h1><field name="name" /></h1>
                    </div>
                    <group string="Task Status / حالة المهمة">
                        <field name="state" widget="statusbar" statusbar_visible="draft,confrim,done,reject,cancel"/>
                    </group>
                    <group>
                        <group string="Task Details / بيانات المهمة">
                            <field name="name"/>
                            <field name="sub_project_id"/>
                            <field name="employee_ids" widget="many2many_tags"/>
                            <field name="user_id" />
                            <field name="state" readonly="1" widget="badge"/>
                        </group>
                        
                        <group string="Schedule &amp; Hours / المواعيد والساعات">
                            <field name="receive_date"/>
                            <field name="delivery_date"/>
                            <field name="required_hours" required="1" widget="float_time" options="{'displaySeconds': True}"/>
                            <field name="start_date" />
                            <field name="end_date" />
                            <field name="work_hours" />
                            <field name="work_hours_display" />
                        </group>
                        <group string="Priority / الأولوية">
                            <field name="priority" />
                        </group>
                    </group>
                    <notebook> 
                        <page string="Description / الوصف">
                            <field name="description"/>
                        </page>
                        <page string="Attachments / المرفقات">
                            <field name="attachment_ids" context="{'default_res_model': 'task', 'default_res_id': id}">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="datas" string="Preview / Download" filename="name" widget="binary"/>
                                    <field name="create_date" string="Upload Date" readonly="1"/>
                                    <field name="create_uid" string="Uploaded By" readonly="1"/>
                                    <field name="mimetype" readonly="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="task_view_list" model="ir.ui.view">
        <field name="name">task.view.list</field>
        <field name="model">task</field>
        <field name="arch" type="xml">
            <list string="">
                <field name="name" />
                <field name="employee_ids" widget="many2many_tags"/>
                <field name="user_id" />
                <field name="start_date" />
                <field name="end_date" />
                <field name="receive_date" />
                <field name="delivery_date" />
                <field name="required_hours" widget="float_time" />
                <field name="priority" 
                    decoration-danger="priority == 'high'"
                    decoration-warning="priority == 'medium'"
                    decoration-success="priority == 'low'"
                    />
                <field name="sub_project_id"/>
                <field name="attachment_ids" />
                <field name="work_hours" />
                <!-- <field name="work_hours_display" /> -->
            </list>
        </field>
    </record>
    <record id="task_view_kanban" model="ir.ui.view">
        <field name="name">task.view.kanban</field>
        <field name="model">task</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="user_id"/>
                <field name="receive_date"/>
                <field name="delivery_date"/>
                <field name="required_hours"/>
                <field name="state"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click o_kanban_record qlk_task_card qlk_task_state_#{record.state.raw_value or 'draft'}">
                            <div class="d-flex justify-content-between align-items-start gap-2">
                                <strong class="o_kanban_record_title"><field name="name"/></strong>
                                <span t-attf-class="badge rounded-pill qlk_task_badge qlk_task_badge_#{record.state.raw_value or 'draft'}">
                                    <field name="state"/>
                                </span>
                            </div>
                            <div class="qlk_task_meta mt-3">
                                <span><i class="fa fa-inbox me-1"/> <field name="receive_date" widget="datetime"/></span>
                                <span><i class="fa fa-paper-plane-o me-1"/> <field name="delivery_date" widget="datetime"/></span>
                                <span class="qlk_task_hours"><i class="fa fa-clock-o me-1"/> <field name="required_hours" widget="float_time"/></span>
                            </div>
                            <div class="text-muted mt-3"><i class="fa fa-user-o me-1"/> <field name="user_id"/></div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <record id="task_action" model="ir.actions.act_window">
        <field name="name">Working Hours</field>
        <field name="res_model">task</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
    </record>

</odoo>
