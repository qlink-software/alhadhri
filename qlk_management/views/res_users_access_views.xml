<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_operational_access" model="ir.ui.view">
        <field name="name">res.users.form.operational.access</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Access Control" name="qlk_access_control" groups="base.group_system">
                    <group string="Existing Operational Groups">
                        <field name="qlk_access_group_ids" widget="many2many_tags" readonly="1" nolabel="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
