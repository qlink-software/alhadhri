<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_department_access" model="ir.ui.view">
        <field name="name">res.users.form.department.access</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Access Control" name="qlk_access_control" groups="base.group_system,qlk_management.group_qlk_admin">
                    <group string="Department Access">
                        <field name="department_role_ids" nolabel="1" context="{'default_user_id': id}">
                            <list editable="bottom">
                                <field name="department_id"/>
                                <field name="role_type" widget="radio"/>
                            </list>
                            <form>
                                <group>
                                    <field name="department_id"/>
                                    <field name="role_type" widget="radio"/>
                                </group>
                            </form>
                        </field>
                    </group>
                    <group string="Effective Access" col="2">
                        <field name="department_ids" widget="many2many_tags" readonly="1"/>
                        <field name="manager_department_ids" widget="many2many_tags" readonly="1"/>
                    </group>
                    <group string="Existing Operational Groups">
                        <field name="qlk_access_group_ids" widget="many2many_tags" readonly="1" nolabel="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
