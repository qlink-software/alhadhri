<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_corporate_case_form_inherit_project" model="ir.ui.view">
            <field name="name">qlk.corporate.case.form.project</field>
            <field name="model">qlk.corporate.case</field>
            <field name="inherit_id" ref="qlk_corporate.view_corporate_case_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form/sheet/group/group[1]" position="after">
                    <group>
                        <field name="agreement_hours"/>
                        <field name="agreement_start_date"/>
                        <field name="agreement_end_date"/>
                        <field name="actual_hours_total" readonly="1"/>
                        <field name="actual_hours_month" readonly="1"/>
                        <field name="planned_hours" readonly="1" widget="float_time"/>
                        <field name="consumed_hours" readonly="1" widget="float_time"/>
                        <field name="remaining_hours" readonly="1" widget="float_time" decoration-danger="remaining_hours &lt; 0"/>
                        <field name="over_hours" readonly="1"/>
                    </group>
                </xpath>
                <xpath expr="//form/sheet/group/group[1]/field[@name='responsible_employee_id']" position="after">
                    <field name="project_id" required="1"/>
                    <field name="service_code" readonly="1" widget="badge"/>
                    <field name="client_legal_code" readonly="1" invisible="1"/>
                    <field name="project_legal_code" readonly="1" invisible="1"/>
                    <field name="record_sequence" readonly="1" invisible="1"/>
                    <field name="engagement_id" readonly="1"/>
                </xpath>
                <xpath expr="//form/sheet/div[@name='button_box']" position="inside">
                    <button class="oe_stat_button"
                            type="object"
                            name="action_open_project_hours"
                            invisible="not engagement_id">
                        <div class="o_stat_info"><span class="o_stat_text">Approved Hours (<field name="actual_hours_total" nolabel="1" readonly="1"/>)</span></div>
                    </button>
                </xpath>
                <xpath expr="//form/sheet/notebook" position="inside">
                    <page string="Client Documents">
                        <group>
                            <!-- <field name="client_document_warning"
                                   nolabel="1"
                                   widget="html"
                                   options="{'invisible': [('client_document_warning_required', '=', False)]}"/> -->
                        </group>
                        <group>
                            <span class="text-muted">Client documents are available on the contact record.</span>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>

        <record id="view_corporate_case_list_inherit_project" model="ir.ui.view">
            <field name="name">qlk.corporate.case.list.project</field>
            <field name="model">qlk.corporate.case</field>
            <field name="inherit_id" ref="qlk_corporate.view_corporate_case_list"/>
            <field name="arch" type="xml">
                <xpath expr="//list/field[@name='name']" position="before">
                    <field name="service_code" widget="badge"/>
                    <field name="client_legal_code" column_invisible="1"/>
                    <field name="project_legal_code" column_invisible="1"/>
                    <field name="record_sequence" column_invisible="1"/>
                </xpath>
                <xpath expr="//list/field[@name='responsible_employee_id']" position="after">
                    <field name="project_id"/>
                    <field name="engagement_id"/>
                    <field name="agreement_hours"/>
                    <field name="planned_hours"/>
                    <field name="consumed_hours"/>
                    <field name="remaining_hours"/>
                    <field name="actual_hours_total"/>
                    <field name="over_hours"/>
                </xpath>
            </field>
        </record>

        <record id="view_corporate_case_search_legal_numbering" model="ir.ui.view">
            <field name="name">qlk.corporate.case.search.legal.numbering</field>
            <field name="model">qlk.corporate.case</field>
            <field name="arch" type="xml">
                <search>
                    <field name="service_code"/>
                    <field name="client_legal_code" invisible="1"/>
                    <field name="project_legal_code" invisible="1"/>
                    <field name="record_code"/>
                    <field name="project_id"/>
                    <field name="client_id"/>
                    <group expand="0" string="Group By">
                        <filter name="group_client_code" string="Client Legal Code"
                                context="{'group_by': 'client_legal_code'}" invisible="1"/>
                        <filter name="group_project_code" string="Project Legal Code"
                                context="{'group_by': 'project_legal_code'}" invisible="1"/>
                        <filter name="group_project" string="Project" context="{'group_by': 'project_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="qlk_corporate.action_corporate_case" model="ir.actions.act_window">
            <field name="search_view_id" ref="view_corporate_case_search_legal_numbering"/>
        </record>

    </data>
</odoo>
