<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_qlk_case_stage_form_inherit" model="ir.ui.view">
            <field name="name">qlk.case.form.stage.inherit</field>
            <field name="model">qlk.case</field>
            <field name="inherit_id" ref="qlk_law.view_qlk_case_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form/header" position="inside">
                </xpath>

                <xpath expr="//div[@id='collapseBasic']//field[@name='name2']" position="before">
                    <field name="service_code" readonly="1"/>
                </xpath>

                <xpath expr="//field[@name='is_new']/.." position="before">
                    <group string="Engagement / Case Engine">
                        <field name="allowed_litigation_degree_ids" invisible="1"/>
                        <field name="client_file_id"/>
                        <field name="project_id"
                               required="1"
                               domain="[('client_file_id', '=', client_file_id), ('service_type', 'in', ['litigation', 'pre_litigation']), ('active', '=', True)]"/>
                        <field name="engagement_id" readonly="1"/>
                        <field name="litigation_degree" invisible="1"/>
                        <field name="litigation_degree_id"
                               string="Litigation Degree"
                               domain="[('id', 'in', allowed_litigation_degree_ids)]"
                               required="project_id"/>
                    </group>
                </xpath>

                <xpath expr="//field[@name='employee_id']" position="attributes">
                    <attribute name="required">0</attribute>
                    <attribute name="domain">['&amp;', ('active', '=', True), '|', '|', '|', ('user_id.partner_id.is_lawyer', '=', True), ('work_contact_id.is_lawyer', '=', True), ('job_id.name', 'ilike', 'lawyer'), ('job_title', 'ilike', 'lawyer')]</attribute>
                </xpath>

                <xpath expr="//field[@name='employee_ids']" position="attributes">
                    <attribute name="domain">['&amp;', ('active', '=', True), '|', '|', '|', ('user_id.partner_id.is_lawyer', '=', True), ('work_contact_id.is_lawyer', '=', True), ('job_id.name', 'ilike', 'lawyer'), ('job_title', 'ilike', 'lawyer')]</attribute>
                </xpath>

                <xpath expr="//field[@name='task_ids']/ancestor::page[1]" position="replace"/>

                <xpath expr="//div[@id='caseAccordion']" position="inside">
                    <div class="accordion-item" name="tasks_hours">
                        <h2 class="accordion-header" id="caseAccordionTasksHours">
                            <div class="accordion-button collapsed o_form_label"
                                 style="cursor:pointer;"
                                 data-bs-toggle="collapse"
                                 data-bs-target="#collapseCaseTasksHours">
                                Tasks &amp; Hours
                            </div>
                        </h2>
                        <div id="collapseCaseTasksHours" class="accordion-collapse collapse" data-bs-parent="#caseAccordion">
                            <div class="accordion-body">
                                <group>
                                    <group>
                                        <field name="case_hours" readonly="1" widget="float_time"/>
                                    </group>
                                    <group>
                                        <button name="action_open_project_tasks"
                                                type="object"
                                                string="Open Tasks"
                                                class="btn-primary"/>
                                    </group>
                                </group>
                                <field name="task_ids"
                                       context="{'default_case_id': id, 'default_partner_id': client_id, 'qlk_require_case_id': True}"
                                       nolabel="1">
                                    <list editable="bottom">
                                        <field name="name" required="1"/>
                                        <field name="case_id" required="1"/>
                                        <field name="project_id"/>
                                        <field name="qlk_project_id" optional="hide"/>
                                        <field name="partner_id" string="Client"/>
                                        <field name="user_ids" widget="many2many_tags"/>
                                        <field name="stage_id"/>
                                        <field name="state" readonly="1"/>
                                        <field name="receive_date"/>
                                        <field name="delivery_date"/>
                                        <field name="required_hours" widget="float_time" required="1" sum="Required Hours"/>
                                        <field name="effective_hours" widget="float_time" readonly="1" sum="Consumed Hours"/>
                                        <field name="remaining_hours" widget="float_time" readonly="1" sum="Remaining Hours"/>
                                    </list>
                                    <form string="Task Hours">
                                        <sheet>
                                            <group>
                                                <group>
                                                    <field name="name" required="1"/>
                                                    <field name="case_id" required="1"/>
                                                    <field name="project_id"/>
                                                    <field name="qlk_project_id" readonly="1"/>
                                                    <field name="partner_id" string="Client"/>
                                                    <field name="user_ids" widget="many2many_tags"/>
                                                </group>
                                                <group>
                                                    <field name="stage_id"/>
                                                    <field name="state" readonly="1"/>
                                                    <field name="receive_date"/>
                                                    <field name="delivery_date"/>
                                                    <field name="required_hours" widget="float_time" required="1"/>
                                                    <field name="effective_hours" widget="float_time" readonly="1"/>
                                                    <field name="remaining_hours" widget="float_time" readonly="1"/>
                                                </group>
                                            </group>
                                            <notebook>
                                                <page string="Timesheets">
                                                    <field name="timesheet_ids" nolabel="1">
                                                        <list editable="bottom">
                                                            <field name="date"/>
                                                            <field name="company_id"/>
                                                            <field name="employee_id"/>
                                                            <field name="name"/>
                                                            <field name="unit_amount" widget="float_time" sum="Hours"/>
                                                            <field name="amount"/>
                                                        </list>
                                                    </field>
                                                </page>
                                            </notebook>
                                        </sheet>
                                    </form>
                                </field>
                            </div>
                        </div>
                    </div>
                </xpath>

                <xpath expr="//sheet//notebook" position="inside">
                    <page string="Client Documents" groups="qlk_management.group_pre_litigation_user">
                        <group>
                        <!-- <field name="client_document_warning"
                               nolabel="1"
                               widget="html"
                               options="{'invisible': [('client_document_warning_required', '=', False)]}"/> -->
                        </group>
                        <field name="client_document_ids" nolabel="1">
                            <list editable="bottom"
                                  decoration-danger="needs_translation and not is_translated"
                                  decoration-success="is_translated">
                                <button name="action_preview" type="object" icon="fa-paperclip" title="Preview" class="btn-link"/>
                                <field name="name"/>
                                <field name="document_type"/>
                                <field name="attachment_id" readonly="1" options="{'no_open': True}"/>
                                <field name="needs_translation"/>
                                <field name="is_translated"/>
                                <field name="related_model"/>
                                <field name="create_date"/>
                            </list>
                        </field>
                    </page>
                </xpath>

                <xpath expr="//field[@name='is_new']" position="attributes">
                    <attribute name="invisible">litigation_flow == 'pre_litigation'</attribute>
                </xpath>
            </field>
        </record>

        <record id="view_qlk_case_project_list" model="ir.ui.view">
            <field name="name">qlk.case.project.list</field>
            <field name="model">qlk.case</field>
            <field name="priority">90</field>
                <field name="arch" type="xml">
                    <list string="Cases" default_order="create_date desc">
                    <field name="service_code"/>
                    <field name="project_id"/>
                    <field name="engagement_id"/>
                    <field name="litigation_degree_id" string="Litigation Degree"/>
                    <field name="name"/>
                    <field name="case_number"/>
                    <field name="case_year"/>
                    <field name="client_id"/>
                    <field name="case_group"/>
                    <field name="second_category"/>
                </list>
                </field>
        </record>

        <record id="view_qlk_case_list_inherit_service_code" model="ir.ui.view">
            <field name="name">qlk.case.list.service.code</field>
            <field name="model">qlk.case</field>
            <field name="inherit_id" ref="qlk_law.view_qlk_case_list"/>
            <field name="arch" type="xml">
                <xpath expr="//list/field[@name='name']" position="before">
                    <field name="service_code"/>
                </xpath>
            </field>
        </record>

        <record id="view_qlk_case_project_search" model="ir.ui.view">
            <field name="name">qlk.case.project.search</field>
            <field name="model">qlk.case</field>
                <field name="arch" type="xml">
                <search>
                    <field name="service_code"/>
                    <field name="project_id"/>
                    <field name="client_id"/>
                    <field name="litigation_degree_id"/>
                    <filter name="degree_first" string="Primary" domain="[('litigation_degree_id.code', '=', 'F')]"/>
                    <filter name="degree_appeal" string="Appeal" domain="[('litigation_degree_id.code', '=', 'A')]"/>
                    <filter name="degree_cassation" string="Cassation" domain="[('litigation_degree_id.code', '=', 'C')]"/>
                    <filter name="degree_execution" string="Execution" domain="[('litigation_degree_id.code', '=', 'E')]"/>
                    <group expand="0" string="Group By">
                        <filter name="group_degree" string="Degree" context="{'group_by': 'litigation_degree_id'}"/>
                        <filter name="group_project" string="Project" context="{'group_by': 'project_id'}"/>
                        <filter name="group_client" string="Client" context="{'group_by': 'client_id'}"/>
                    </group>
                </search>
            </field>
        </record>
    </data>
</odoo>
