<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- هذه الواجهات لإدارة قائمة تصنيفات جهة الاتصال بشكل مركزي وقابل للتوسع. -->
    <record id="view_qlk_contact_classification_list" model="ir.ui.view">
        <field name="name">qlk.contact.classification.list</field>
        <field name="model">qlk.contact.classification</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence"/>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_qlk_contact_classification_form" model="ir.ui.view">
        <field name="name">qlk.contact.classification.form</field>
        <field name="model">qlk.contact.classification</field>
        <field name="arch" type="xml">
            <form string="Contact Classification">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_qlk_contact_classification" model="ir.actions.act_window">
        <field name="name">Contact Classifications</field>
        <field name="res_model">qlk.contact.classification</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_qlk_contact_classification"
              name="Contact Classifications"
              parent="contacts.res_partner_menu_config"
              action="action_qlk_contact_classification"
              groups="qlk_management.group_bd_user,qlk_management.group_bd_manager"
              sequence="25"/>

    <!-- هذا الامتداد يضيف التصنيف في بحث العملاء لتسهيل الفلترة. -->
    <record id="view_res_partner_filter_client_data_classification_inherit" model="ir.ui.view">
        <field name="name">res.partner.filter.client.data.classification.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="qlk_management.view_res_partner_filter_client_data"/>
        <field name="arch" type="xml">
            <xpath expr="//search/field[@name='phone']" position="after">
                <field name="classification_id"/>
            </xpath>
        </field>
    </record>
</odoo>
