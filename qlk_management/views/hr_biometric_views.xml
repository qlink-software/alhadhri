<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_qlk_biometric_device_tree" model="ir.ui.view">
            <field name="name">qlk.biometric.device.tree</field>
            <field name="model">qlk.biometric.device</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="endpoint_url"/>
                    <field name="last_sync_at"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="view_qlk_biometric_device_form" model="ir.ui.view">
            <field name="name">qlk.biometric.device.form</field>
            <field name="model">qlk.biometric.device</field>
            <field name="arch" type="xml">
                <form string="Biometric Device">
                    <header>
                        <button name="action_sync_now" type="object" string="Sync Now" class="btn-primary"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="active"/>
                                <field name="endpoint_url"/>
                                <field name="api_token" password="True"/>
                            </group>
                            <group>
                                <field name="request_timeout"/>
                                <field name="verify_ssl"/>
                                <field name="last_sync_at" readonly="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="User Mapping">
                                <field name="user_map_ids" context="{'default_device_id': id}">
                                    <list editable="bottom">
                                        <field name="device_user_code"/>
                                        <field name="employee_id"/>
                                        <field name="active"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Sync Logs">
                                <field name="log_ids" readonly="1">
                                    <list>
                                        <field name="event_time"/>
                                        <field name="device_user_code"/>
                                        <field name="employee_id"/>
                                        <field name="event_type"/>
                                        <field name="status"/>
                                        <field name="external_ref"/>
                                        <field name="note"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_qlk_biometric_devices" model="ir.actions.act_window">
            <field name="name">Biometric Devices</field>
            <field name="res_model">qlk.biometric.device</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="view_qlk_biometric_device_tree"/>
        </record>

        <!-- هذا المينيو لإدارة تكامل البصمة من داخل HR بدون إنشاء تطبيق مستقل. -->
        <menuitem id="menu_qlk_biometric_root"
                  name="Biometric Integration"
                  parent="hr.menu_hr_root"
                  action="action_qlk_biometric_devices"
                  sequence="60"
                  groups="hr.group_hr_manager"/>
    </data>
</odoo>
