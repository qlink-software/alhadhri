<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_bd_engagement_letter_list" model="ir.ui.view">
        <field name="name">bd.engagement.letter.list</field>
        <field name="model">bd.engagement.letter</field>
        <field name="arch" type="xml">
            <list string="Engagement Letters">
                <field name="code"/>
                <field name="client_code"/>
                <field name="partner_id"/>
                <field name="contract_type"/>
                <field name="service_type"/>
                <field name="date"/>
                <field name="total_cases"/>
                <field name="total_hours_used" widget="float_time"/>
                <field name="total_amount"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_bd_engagement_letter_form" model="ir.ui.view">
        <field name="name">bd.engagement.letter.form</field>
        <field name="model">bd.engagement.letter</field>
        <field name="arch" type="xml">
            <form string="Engagement Letter">
                <header>
                    <button name="action_open_report_wizard" type="object" string="Print Report" class="btn-secondary"/>
                    <button name="action_send_manager_approval" type="object" string="Send to Manager Approval"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_manager_approve" type="object" string="Manager Approve" class="btn-success"
                            groups="qlk_management.group_bd_manager"
                            invisible="state != 'waiting_manager_approval' or approval_role != 'manager'"/>
                    <button name="action_manager_approve" type="object" string="Manager Approve" class="btn-success"
                            groups="qlk_management.group_bd_manager"
                            invisible="state != 'waiting_manager_approval' or approval_role != 'assistant_manager'"/>
                    <button name="action_manager_reject" type="object" string="Reject with Reason" class="btn-danger"
                            groups="qlk_management.group_bd_manager"
                            invisible="state not in ('waiting_manager_approval', 'approved_manager') or approval_role != 'manager'"/>
                    <button name="action_manager_reject" type="object" string="Reject with Reason" class="btn-danger"
                            groups="qlk_management.group_bd_manager"
                            invisible="state not in ('waiting_manager_approval', 'approved_manager') or approval_role != 'assistant_manager'"/>
                    <button name="action_send_client_approval" type="object" string="Send to Client Approval"
                            class="btn-primary"
                            invisible="state != 'approved_manager'"/>
                    <button name="action_client_approve" type="object" string="Client Approve" class="btn-success"
                            invisible="state != 'waiting_client_approval'"/>
                    <button name="action_client_reject" type="object" string="Client Reject" class="btn-danger"
                            invisible="state != 'waiting_client_approval'"/>
                    <button name="action_reset_to_draft" type="object" string="Reset to Draft"
                            invisible="state not in ('rejected', 'cancelled')"/>
                    <button name="action_create_case" type="object" string="Create Case" class="btn-primary"
                            invisible="state != 'approved_client' or service_type not in ('litigation', 'mixed')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,waiting_manager_approval,approved_manager,waiting_client_approval,approved_client,rejected,cancelled"/>
                </header>
                <sheet>
                    <div class="alert alert-warning o_qlk_hours_notice">You must enter hours.</div>
                    <div class="oe_button_box" name="button_box">
                        <button type="object" name="action_open_cases" class="oe_stat_button" icon="fa-balance-scale">
                            <field name="case_count" widget="statinfo" string="Cases"/>
                        </button>
                        <button type="object" name="action_open_pre_litigation" class="oe_stat_button" icon="fa-file-text-o">
                            <field name="pre_litigation_count" widget="statinfo" string="Pre-Litigation"/>
                        </button>
                        <button type="object" name="action_open_arbitration_cases" class="oe_stat_button" icon="fa-gavel">
                            <field name="arbitration_count" widget="statinfo" string="Arbitration"/>
                        </button>
                        <button type="object" name="action_open_corporate_cases" class="oe_stat_button" icon="fa-building-o">
                            <field name="corporate_count" widget="statinfo" string="Corporate"/>
                        </button>
                    </div>
                    <group string="Client &amp; General Info">
                        <group>
                            <field name="code" readonly="1"/>
                            <field name="date"/>
                            <field name="currency_id"/>
                            <field name="contract_type"/>
                            <field name="service_type"/>
                            <field name="litigation_degree_ids" widget="many2many_tags"
                                   invisible="service_type not in ('litigation', 'mixed')"/>
                            <field name="retainer_type"/>
                            <field name="retainer_period"
                                   modifiers="{'invisible': ['|', ('billing_type', '=', 'free'), ('contract_type', '!=', 'retainer')]}"/>
                            <field name="approval_role"/>
                            <field name="client_id" required="1"/>
                            <field name="billing_type"/>
                            <field name="notify_datetime"/>
                            <field name="estimated_hours"
                                   modifiers="{'invisible': [('billing_type', '!=', 'free')]}"/>
                            <field name="agreed_hours" widget="float_time" invisible="contract_type != 'hours'"/>
                            <field name="agreed_case_count" invisible="contract_type != 'cases'"/>
                        </group>
                        <group>
                            <field name="lawyer_employee_id" domain="[('user_id.partner_id.is_lawyer', '=', True)]"/>
                            <field name="lawyer_ids" widget="many2many_tags"
                                   domain="[('user_id.partner_id.is_lawyer', '=', True)]"/>
                            <field name="lawyer_cost_hour" readonly="1"/>
                            <field name="client_code" readonly="1" modifiers="{'invisible': [('client_code', '=', False)]}"/>
                            <field name="proposal_id" readonly="1" options="{'no_create': True}"/>
                            <field name="reviewer_id"/>
                            <field name="total_hours_used" readonly="1" widget="float_time"/>
                            <field name="remaining_hours" readonly="1" widget="float_time"
                                   decoration-danger="remaining_hours &lt; 0"/>
                            <field name="total_cases" readonly="1"/>
                            <field name="remaining_cases" readonly="1"
                                   decoration-danger="remaining_cases &lt; 0"/>
                            <field name="consumption_label" readonly="1" widget="badge"
                                   decoration-danger="over_consumed"
                                   invisible="not over_consumed"/>
                        </group>
                    </group>
                    <group string="Retainer Tracking" modifiers="{'invisible': ['|', '|', ('billing_type', '=', 'free'), ('contract_type', '!=', 'retainer'), ('retainer_period', '=', False)]}">
                        <group>
                            <!-- Standard Odoo project is the primary source for task timesheets. -->
                            <field name="project_id"/>
                            <field name="allocated_hours"/>
                            <field name="used_hours" readonly="1"/>
                            <field name="remaining_hours" readonly="1"/>
                            <field name="exception_approved"/>
                        </group>
                        <group>
                            <!-- Monthly retainers watch the current month; annual retainers use the custom year window. -->
                            <field name="year_start_date"
                                   modifiers="{'invisible': [('retainer_period', '!=', 'annual')]}"/>
                            <field name="year_end_date"
                                   modifiers="{'invisible': [('retainer_period', '!=', 'annual')]}"/>
                            <field name="monthly_hours_limit"
                                   modifiers="{'invisible': [('retainer_period', '!=', 'monthly')]}"/>
                            <field name="monthly_used_hours" readonly="1"
                                   modifiers="{'invisible': [('retainer_period', '!=', 'monthly')]}"/>
                            <field name="retainer_usage_state" widget="badge"
                                   decoration-success="retainer_usage_state == 'success'"
                                   decoration-warning="retainer_usage_state == 'warning'"
                                   decoration-danger="retainer_usage_state == 'danger'"/>
                        </group>
                        <group colspan="2">
                            <!-- Visual countdown for retainer consumption. -->
                            <field name="retainer_usage_percent" widget="progressbar" options="{'max_value': 100}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Scope / Legal Fees" modifiers="{'invisible': [('billing_type', '=', 'free')]}">
                            <!-- Structured service lines with frozen lawyer cost and stored subtotal. -->
                            <field name="legal_fees_lines" nolabel="1"
                                   context="{'default_currency_id': currency_id, 'default_letter_id': id, 'default_assigned_lawyer_id': lawyer_employee_id, 'default_service_type': retainer_type}">
                                <list editable="bottom">
                                    <field name="currency_id" column_invisible="1"/>
                                    <field name="service_name"/>
                                    <field name="service_type"/>
                                    <field name="assigned_lawyer_id" domain="[('user_id.partner_id.is_lawyer', '=', True)]"/>
                                    <field name="quantity"/>
                                    <field name="unit_price" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="discount_type"/>
                                    <field name="discount"/>
                                    <field name="lawyer_cost" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="subtotal" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                    <field name="due_date"/>
                                </list>
                            </field>
                            <field name="scope_of_work"/>
                            <!-- Summary footer for the stored services total. -->
                            <group class="oe_subtotal_footer oe_right">
                                <field name="currency_id" invisible="1"/>
                                <label for="total_legal_fees" string="Total Legal Fees"/>
                                <div>
                                    <field name="total_legal_fees" widget="monetary" options="{'currency_field': 'currency_id'}" class="oe_inline"/>
                                </div>
                            </group>
                        </page>
                        <page string="Client Attachments">
                            <field name="client_attachment_ids" widget="many2many_binary" nolabel="1"/>
                        </page>
                        <page string="Attachments for Translation">
                            <group>
                                <field name="translation_status" readonly="1"/>
                            </group>
                            <field name="translation_attachment_ids" widget="many2many_binary" nolabel="1"/>
                        </page>
                        <page string="Signed Copy">
                            <group>
                                <field name="signed_document_ids" widget="many2many_binary"/>
                                <field name="signed_on" readonly="1"/>
                                <field name="client_code_generated" readonly="1"/>
                            </group>
                        </page>
                        <page string="Rejection Reason">
                            <field name="rejection_reason" nolabel="1"/>
                        </page>
                        <page string="Tasks / Hours">
                            <field name="time_entry_ids" context="{'default_engagement_id': id, 'default_department': 'management'}">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="department"/>
                                    <field name="employee_id"/>
                                    <field name="hours_spent" widget="float_time" options="{'displaySeconds': True}"/>
                                    <field name="date_start"/>
                                </list>
                                <form string="Task / Hours">
                                    <sheet>
                                        <group>
                                            <field name="name"/>
                                            <field name="employee_id"/>
                                            <field name="department"/>
                                            <field name="hours_spent" widget="float_time" options="{'displaySeconds': True}"/>
                                            <field name="date_start"/>
                                            <field name="description"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                    </notebook>
                    <group string="Financial &amp; Billing Info" modifiers="{'invisible': [('billing_type', '=', 'free')]}">
                        <!-- <field name="total_amount" readonly="1"/>
                        <field name="payment_status" readonly="1"/> -->
                        <group>
                            <field name="invoice_id" options="{'no_create': True}" readonly="1"
                                   modifiers="{'invisible': [('billing_type', '=', 'free')]}"/>
                            <field name="invoice_state" readonly="1"
                                   modifiers="{'invisible': ['|', ('billing_type', '=', 'free'), ('invoice_id', '=', False)]}"/>
                        </group>
                        <group>
                            <button name="action_create_invoice" type="object" string="Create Invoice"
                                    class="btn-secondary"
                                    modifiers="{'invisible': ['|', ('billing_type', '=', 'free'), ('invoice_id', '!=', False)]}"/>
                        </group>
                    </group>
                    <field name="over_consumed" invisible="1"/>
                    <field name="can_approve" invisible="1"/>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

    <record id="view_bd_engagement_letter_search" model="ir.ui.view">
        <field name="name">bd.engagement.letter.search</field>
        <field name="model">bd.engagement.letter</field>
        <field name="arch" type="xml">
            <search>
                <field name="code"/>
                <field name="client_code"/>
                <field name="partner_id"/>
                <field name="contract_type"/>
                <field name="service_type"/>
                <filter name="waiting" string="Waiting Approval" domain="[('state','=','waiting_manager_approval')]"/>
                <filter name="approved" string="Approved" domain="[('state','=','approved_client')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_contract" string="Contract Type" domain="[]" context="{'group_by': 'contract_type'}"/>
                    <filter name="group_service" string="Service Type" domain="[]" context="{'group_by': 'service_type'}"/>
                    <filter name="group_state" string="State" domain="[]" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_bd_engagement_letter_kanban" model="ir.ui.view">
        <field name="name">bd.engagement.letter.kanban</field>
        <field name="model">bd.engagement.letter</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" default_order="state">
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click card">
                            <div class="d-flex justify-content-between align-items-center">
                                <strong t-esc="record.code and record.code.value or ''"/>
                                <span class="badge bg-primary" t-esc="record.contract_type and record.contract_type.value or ''"/>
                            </div>
                            <div class="text-muted">
                                <span>Client:</span>
                                <t t-esc="record.partner_id and record.partner_id.raw_value and record.partner_id.raw_value[1] or ''"/>
                            </div>
                            <div class="text-muted">
                                <span>Reference:</span>
                                <t t-esc="record.reference and record.reference.value or ''"/>
                            </div>
                            <div class="text-muted">
                                <span>Total:</span>
                                <t t-esc="record.total_amount and record.total_amount.value or 0.0"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_bd_engagement_letter" model="ir.actions.act_window">
        <field name="name">Engagement Letters</field>
        <field name="res_model">bd.engagement.letter</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_bd_engagement_letter_search"/>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'kanban', 'view_id': ref('view_bd_engagement_letter_kanban')}),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_bd_engagement_letter_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_bd_engagement_letter_form')})]"/>
    </record>

</odoo>
