<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_qlk_department_list" model="ir.ui.view">
        <field name="name">qlk.department.list</field>
        <field name="model">qlk.department</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_qlk_department_form" model="ir.ui.view">
        <field name="name">qlk.department.form</field>
        <field name="model">qlk.department</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group string="Menu Groups">
                            <field name="user_group_id" readonly="1"/>
                            <field name="manager_group_id" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_qlk_department" model="ir.actions.act_window">
        <field name="name">Legal Departments</field>
        <field name="res_model">qlk.department</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_qlk_department_access"
              name="Legal Departments"
              parent="base.menu_users"
              action="action_qlk_department"
              groups="base.group_system,qlk_management.group_qlk_admin"
              sequence="65"/>
</odoo>
