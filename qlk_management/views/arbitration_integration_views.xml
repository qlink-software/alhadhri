<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_arbitration_case_form_inherit_project" model="ir.ui.view">
            <field name="name">qlk.arbitration.case.form.project</field>
            <field name="model">qlk.arbitration.case</field>
            <field name="inherit_id" ref="qlk_arbitration.view_arbitration_case_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form/sheet/group/group[1]/field[@name='arbitration_center']" position="after">
                    <field name="project_id" required="1"/>
                    <field name="service_code" readonly="1" widget="badge"/>
                    <field name="client_legal_code" readonly="1"/>
                    <field name="project_legal_code" readonly="1"/>
                    <field name="record_sequence" readonly="1"/>
                    <field name="engagement_id" readonly="1"/>
                </xpath>
                <xpath expr="//form/sheet/group/group[2]" position="inside">
                    <field name="agreement_hours"/>
                    <field name="agreement_start_date"/>
                    <field name="agreement_end_date"/>
                    <field name="planned_hours" readonly="1" widget="float_time"/>
                    <field name="consumed_hours" readonly="1" widget="float_time"/>
                    <field name="remaining_hours" readonly="1" widget="float_time" decoration-danger="remaining_hours &lt; 0"/>
                    <field name="actual_hours_total" readonly="1"/>
                    <field name="actual_hours_month" readonly="1"/>
                    <field name="over_hours" readonly="1"/>
                </xpath>
                <xpath expr="//form/sheet/group[1]" position="before">
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_project_hours"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-clock-o"
                                invisible="not engagement_id">
                            <field name="actual_hours_total" string="Approved Hours"/>
                        </button>
                    </div>
                </xpath>
                <xpath expr="//form/sheet/notebook" position="inside">
                    <page string="Client Documents" groups="qlk_management.group_pre_litigation_user">
                        <group>
                            <!-- <field name="client_document_warning"
                                   nolabel="1"
                                   widget="html"
                                   options="{'invisible': [('client_document_warning_required', '=', False)]}"/> -->
                        </group>
                        <field name="client_document_ids" nolabel="1">
                            <list editable="bottom"
                                  decoration-danger="needs_translation and not is_translated"
                                  decoration-success="is_translated">
                                <button name="action_preview" type="object" icon="fa-paperclip" title="Preview" class="btn-link"/>
                                <field name="name"/>
                                <field name="document_type"/>
                                <field name="attachment_id" readonly="1" options="{'no_open': True}"/>
                                <field name="needs_translation"/>
                                <field name="is_translated"/>
                                <field name="related_model"/>
                                <field name="create_date"/>
                            </list>
                        </field>
                    </page>
                </xpath>
            </field>
        </record>

        <record id="view_arbitration_case_list_inherit_project" model="ir.ui.view">
            <field name="name">qlk.arbitration.case.list.project</field>
            <field name="model">qlk.arbitration.case</field>
            <field name="inherit_id" ref="qlk_arbitration.view_arbitration_case_list"/>
            <field name="arch" type="xml">
                <xpath expr="//list/field[@name='case_number']" position="before">
                    <field name="service_code" widget="badge"/>
                    <field name="client_legal_code"/>
                    <field name="project_legal_code"/>
                    <field name="record_sequence"/>
                </xpath>
                <xpath expr="//list/field[@name='responsible_employee_id']" position="after">
                    <field name="project_id"/>
                    <field name="engagement_id"/>
                    <field name="planned_hours"/>
                    <field name="consumed_hours"/>
                    <field name="remaining_hours"/>
                    <field name="actual_hours_total"/>
                    <field name="over_hours"/>
                </xpath>
            </field>
        </record>

        <record id="view_arbitration_case_search_legal_numbering" model="ir.ui.view">
            <field name="name">qlk.arbitration.case.search.legal.numbering</field>
            <field name="model">qlk.arbitration.case</field>
            <field name="arch" type="xml">
                <search>
                    <field name="service_code"/>
                    <field name="client_legal_code"/>
                    <field name="project_legal_code"/>
                    <field name="record_code"/>
                    <field name="project_id"/>
                    <field name="claimant_id"/>
                    <group expand="0" string="Group By">
                        <filter name="group_client_code" string="Client Legal Code" context="{'group_by': 'client_legal_code'}"/>
                        <filter name="group_project_code" string="Project Legal Code" context="{'group_by': 'project_legal_code'}"/>
                        <filter name="group_project" string="Project" context="{'group_by': 'project_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="qlk_arbitration.action_arbitration_case" model="ir.actions.act_window">
            <field name="search_view_id" ref="view_arbitration_case_search_legal_numbering"/>
        </record>

    </data>
</odoo>
