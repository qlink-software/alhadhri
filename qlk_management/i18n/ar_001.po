#. module: qlk_management
#: model:mail.template,body_html:qlk_management.mail_template_pre_litigation_translation
msgid ""
"<div>\n"
"                <p>Dear MP Office,</p>\n"
"\n"
"                <p>Please find attached documents that require translation.</p>\n"
"\n"
"                <p><strong>Client Details:</strong></p>\n"
"                <ul>\n"
"                    <li><strong>Client Name:</strong> {{ object.client_id.name or '' }}</li>\n"
"                    <li><strong>Client Code:</strong> {{ object.project_id.client_code or object.client_id.code or '' }}</li>\n"
"                </ul>\n"
"\n"
"                <p><strong>Case / Reference:</strong></p>\n"
"                <ul>\n"
"                    <li><strong>Reference:</strong> {{ object.name or object.subject or '' }}</li>\n"
"                </ul>\n"
"\n"
"                <p>The required documents are attached for your action.</p>\n"
"\n"
"                <p>\n"
"                    Best Regards,<br/>\n"
"                    {{ user.name }}\n"
"                </p>\n"
"            </div>\n"
"        "
msgstr ""
"<div>\n"
"                <p>مكتب الشريك الإداري المحترم,</p>\n"
"\n"
"                <p>Please find attached documents that require translation.</p>\n"
