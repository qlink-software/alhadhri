<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Agreement permissions / صلاحيات الاتفاقيات -->
    <record id="category_engagement_letters" model="ir.module.category">
        <field name="name">Agreements</field><field name="parent_id" ref="qlk_management_manage_category"/><field name="sequence" eval="20"/>
    </record>
    <record id="group_el_user" model="res.groups">
        <field name="name">Agreement User</field><field name="category_id" ref="category_engagement_letters"/><field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>
    <record id="group_el_manager" model="res.groups">
        <field name="name">Agreement Manager</field><field name="category_id" ref="category_engagement_letters"/><field name="implied_ids" eval="[(4, ref('group_el_user'))]"/>
    </record>
</odoo>
