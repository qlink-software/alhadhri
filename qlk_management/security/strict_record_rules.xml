<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Department security domain:
        - Department manager: sees all records in managed departments.
        - Department user: sees only records assigned to their user.
        This is server-side security and applies to list, kanban, form, search, export, reports and RPC.
    -->

    <function name="write" model="ir.model.data">
        <value model="ir.model.data" search="[('module', '=', 'qlk_management'), ('name', 'in', ['rule_qlk_project_manager', 'rule_qlk_project_member', 'rule_qlk_project_viewer'])]"/>
        <value eval="{'noupdate': False}"/>
    </function>

    <!-- Disable older broad rules only when their XML IDs exist in the target database. -->
    <function model="ir.rule" name="_qlk_disable_legacy_rules"/>

    <record id="rule_qlk_project_member" model="ir.rule">
        <field name="name">QLK Project Department Isolation</field>
        <field name="model_id" ref="model_qlk_project"/>
        <field name="domain_force">['|', ('department_id', 'in', user.manager_department_ids.ids), '&amp;', ('department_id', 'in', user.department_ids.ids), '|', ('access_lawyer_id', '=', user.id), ('access_lawyer_ids', 'in', [user.id])]</field>
        <field name="groups" eval="[(6, 0, [ref('base.group_user')])]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

