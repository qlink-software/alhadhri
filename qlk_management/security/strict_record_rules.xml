<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="rule_task_user" model="ir.rule">
            <field name="name">Working Hours User</field>
            <field name="model_id" ref="model_task"/>
            <field name="domain_force">['|', ('user_id', '=', user.id), ('employee_ids.user_id', 'in', [user.id])]</field>
            <field name="groups" eval="[(6, 0, [ref('qlk_task_management.group_task_user')])]"/>
        </record>
        <record id="rule_task_manager" model="ir.rule">
            <field name="name">Working Hours Manager</field>
            <field name="model_id" ref="model_task"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(6, 0, [ref('qlk_task_management.group_task_manager')])]"/>
        </record>

