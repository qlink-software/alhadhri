<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Client permissions / صلاحيات العملاء -->
    <record id="category_client_files" model="ir.module.category">
        <field name="name">Clients</field><field name="parent_id" ref="qlk_management_manage_category"/><field name="sequence" eval="30"/>
    </record>
    <record id="group_client_file_user" model="res.groups">
        <field name="name">Client User</field><field name="category_id" ref="category_client_files"/><field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>
    <record id="group_client_file_manager" model="res.groups">
        <field name="name">Client Manager</field><field name="category_id" ref="category_client_files"/><field name="implied_ids" eval="[(4, ref('group_client_file_user'))]"/>
    </record>
</odoo>
