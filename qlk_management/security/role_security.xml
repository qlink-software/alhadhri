<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_qlk_access_roles" model="ir.module.category">
        <field name="name">QLink LawPro Access</field>
        <field name="sequence" eval="2"/>
    </record>

    <record id="group_qlk_bd_team" model="res.groups">
        <field name="name">BD Team</field>
        <field name="category_id" ref="qlk_management.module_qlk_access_roles"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_qlk_lawyers" model="res.groups">
        <field name="name">Lawyers</field>
        <field name="category_id" ref="qlk_management.module_qlk_access_roles"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_qlk_managers" model="res.groups">
        <field name="name">Managers</field>
        <field name="category_id" ref="qlk_management.module_qlk_access_roles"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_qlk_admin" model="res.groups">
        <field name="name">Admin</field>
        <field name="category_id" ref="qlk_management.module_qlk_access_roles"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('base.group_system'))]"/>
    </record>

    <!-- Map existing operational groups to the new access roles without changing their names. -->
    <record id="bd_manager_group" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('qlk_management.group_qlk_managers')), (4, ref('qlk_management.group_qlk_bd_team'))]"/>
    </record>
    <record id="bd_assistant_manager_group" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('qlk_management.group_qlk_bd_team'))]"/>
    </record>
    <record id="group_legal_user" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('qlk_management.group_qlk_lawyers'))]"/>
    </record>
    <record id="group_legal_manager" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('qlk_management.group_qlk_managers')), (4, ref('qlk_management.group_qlk_lawyers'))]"/>
    </record>
    <record id="qlk_law.group_qlk_law_lawyer" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('qlk_management.group_qlk_lawyers'))]"/>
    </record>
    <record id="qlk_law.group_qlk_law_manager" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('qlk_management.group_qlk_managers'))]"/>
    </record>
    <record id="qlk_law.group_qlk_law_admin" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('qlk_management.group_qlk_admin'))]"/>
    </record>
</odoo>
