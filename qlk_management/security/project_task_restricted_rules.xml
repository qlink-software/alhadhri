<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="rule_project_project_restricted_user" model="ir.rule">
            <field name="name">Project Restricted User</field>
            <field name="model_id" ref="project.model_project_project"/>
            <field name="domain_force">['&amp;', '|', ('company_id', '=', False), ('company_id', 'in', company_ids), '|', '|', ('user_id', '=', user.id), ('authorized_user_ids', 'in', [user.id]), ('create_uid', '=', user.id)]</field>
            <field name="groups" eval="[(6, 0, [ref('qlk_management.group_project_restricted_user')])]"/>
        </record>

        <record id="rule_project_project_manager_all" model="ir.rule">
            <field name="name">Project Managers Full Project Access</field>
            <field name="model_id" ref="project.model_project_project"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(6, 0, [ref('qlk_management.group_project_manager'), ref('qlk_management.group_bd_manager'), ref('qlk_management.group_el_manager'), ref('qlk_task_management.group_task_manager'), ref('base.group_system')])]"/>
        </record>

        <record id="rule_project_task_restricted_user" model="ir.rule">
            <field name="name">Project Task Restricted User</field>
            <field name="model_id" ref="project.model_project_task"/>
            <field name="domain_force">['&amp;', '|', ('company_id', '=', False), ('company_id', 'in', company_ids), '|', '|', '|', ('user_id', '=', user.id), ('user_ids', 'in', [user.id]), ('project_id.authorized_user_ids', 'in', [user.id]), ('create_uid', '=', user.id)]</field>
            <field name="groups" eval="[(6, 0, [ref('qlk_management.group_project_restricted_user')])]"/>
        </record>

        <record id="rule_project_task_manager_all" model="ir.rule">
            <field name="name">Project Managers Full Task Access</field>
            <field name="model_id" ref="project.model_project_task"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(6, 0, [ref('qlk_management.group_project_manager'), ref('qlk_management.group_bd_manager'), ref('qlk_management.group_el_manager'), ref('qlk_task_management.group_task_manager'), ref('base.group_system')])]"/>
        </record>
    </data>
</odoo>
