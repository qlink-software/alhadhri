<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <function model="ir.model.data" name="write">
            <value model="ir.model.data" search="['|', ('module', '=', 'qlk_management'), ('module', '=', 'project'), ('name', 'in', ['rule_project_project_restricted_user', 'rule_project_project_manager_all', 'rule_project_task_restricted_user', 'rule_project_task_manager_all', 'project_public_members_rule', 'task_visibility_rule', 'task_visibility_rule_project_user', 'ir_rule_private_task', 'project_manager_all_project_tasks_rule'])]"/>
            <value eval="{'noupdate': False}"/>
        </function>

        <record id="project.project_public_members_rule" model="ir.rule">
            <field name="active" eval="False"/>
        </record>
        <record id="project.task_visibility_rule" model="ir.rule">
            <field name="active" eval="False"/>
        </record>
        <record id="project.task_visibility_rule_project_user" model="ir.rule">
            <field name="active" eval="False"/>
        </record>
        <record id="project.ir_rule_private_task" model="ir.rule">
            <field name="active" eval="False"/>
        </record>
        <record id="project.project_manager_all_project_tasks_rule" model="ir.rule">
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <record id="rule_project_project_restricted_user" model="ir.rule">
            <field name="name">Project User Own Records</field>
            <field name="model_id" ref="project.model_project_project"/>
            <field name="domain_force">['|', ('authorized_user_ids', 'in', [user.id]), ('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(6, 0, [ref('qlk_management.group_project_user')])]"/>
        </record>

        <record id="rule_project_project_manager_all" model="ir.rule">
            <field name="name">Project Managers Full Project Access</field>
            <field name="model_id" ref="project.model_project_project"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(6, 0, [])]"/>
            <field name="active" eval="False"/>
        </record>

        <record id="rule_project_task_restricted_user" model="ir.rule">
            <field name="name">Project Task User Own Records</field>
            <field name="model_id" ref="project.model_project_task"/>
            <field name="domain_force">['|', ('user_ids', 'in', [user.id]), ('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(6, 0, [ref('qlk_management.group_project_user')])]"/>
        </record>

        <record id="rule_project_task_manager_all" model="ir.rule">
            <field name="name">Project Managers Full Task Access</field>
            <field name="model_id" ref="project.model_project_task"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(6, 0, [])]"/>
            <field name="active" eval="False"/>
        </record>
    </data>
</odoo>
