<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="rule_qlk_employee_document_user" model="ir.rule">
            <field name="name">Employee Document User</field>
            <field name="model_id" ref="model_qlk_employee_document"/>
            <field name="domain_force">[('requested_by', '=', user.id)]</field>
            <field name="groups" eval="[(6, 0, [ref('qlk_management.group_hr_user')])]"/>
        </record>
        <record id="rule_qlk_employee_document_manager" model="ir.rule">
            <field name="name">Employee Document Manager</field>
            <field name="model_id" ref="model_qlk_employee_document"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(6, 0, [ref('qlk_management.group_hr_manager')])]"/>
        </record>
    </data>
</odoo>
