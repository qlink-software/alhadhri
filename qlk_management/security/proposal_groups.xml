<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Proposal permissions / صلاحيات العروض -->
    <record id="category_business_development" model="ir.module.category">
        <field name="name">Proposals</field><field name="parent_id" ref="qlk_management_manage_category"/><field name="sequence" eval="10"/>
    </record>
    <record id="group_bd_user" model="res.groups">
        <field name="name">Proposal User</field><field name="category_id" ref="category_business_development"/><field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>
    <record id="group_bd_manager" model="res.groups">
        <field name="name">Proposal Manager</field><field name="category_id" ref="category_business_development"/><field name="implied_ids" eval="[(4, ref('group_bd_user'))]"/>
    </record>
</odoo>
