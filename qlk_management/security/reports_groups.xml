<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Reporting permissions / صلاحيات التقارير -->
    <record id="category_reports" model="ir.module.category">
        <field name="name">Reports</field><field name="parent_id" ref="qlk_management_manage_category"/><field name="sequence" eval="70"/>
    </record>
    <record id="group_reports_user" model="res.groups">
        <field name="name">Reports User</field><field name="category_id" ref="category_reports"/><field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>
    <record id="group_reports_manager" model="res.groups">
        <field name="name">Reports Manager</field><field name="category_id" ref="category_reports"/><field name="implied_ids" eval="[(4, ref('group_reports_user'))]"/>
    </record>
</odoo>
