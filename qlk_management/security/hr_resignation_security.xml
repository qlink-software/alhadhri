<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="rule_hr_resignation_request_employee_own" model="ir.rule">
            <field name="name">HR Resignation Request Own</field>
            <field name="model_id" ref="model_hr_resignation_request"/>
            <field name="domain_force">[("employee_id.user_id", "=", user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="rule_hr_resignation_request_direct_manager" model="ir.rule">
            <field name="name">HR Resignation Request Direct Manager</field>
            <field name="model_id" ref="model_hr_resignation_request"/>
            <field name="domain_force">[("manager_id", "=", user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="rule_hr_resignation_request_hr_all" model="ir.rule">
            <field name="name">HR Resignation Request HR All</field>
            <field name="model_id" ref="model_hr_resignation_request"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('hr.group_hr_manager')), (4, ref('qlk_management.group_mp'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>
    </data>
</odoo>
