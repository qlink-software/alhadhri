<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="rule_hr_resignation_request_user" model="ir.rule">
            <field name="name">HR Resignation Request User</field>
            <field name="model_id" ref="model_hr_resignation_request"/>
            <field name="domain_force">['|', ('employee_id.user_id', '=', user.id), ('manager_id', '=', user.id)]</field>
            <field name="groups" eval="[(6, 0, [ref('qlk_management.group_hr_user')])]"/>
        </record>

        <record id="rule_hr_resignation_request_manager" model="ir.rule">
            <field name="name">HR Resignation Request Manager</field>
            <field name="model_id" ref="model_hr_resignation_request"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(6, 0, [ref('qlk_management.group_hr_manager')])]"/>
        </record>
    </data>
</odoo>
