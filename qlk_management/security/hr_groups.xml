<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- HR administration remains independent from legal roles. -->
    <record id="category_human_resources" model="ir.module.category">
        <field name="name">Human Resources</field><field name="parent_id" ref="qlk_management_manage_category"/><field name="sequence" eval="60"/>
    </record>
    <record id="group_hr_user" model="res.groups">
        <field name="name">HR User</field><field name="category_id" ref="category_human_resources"/><field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>
    <record id="group_hr_manager" model="res.groups">
        <field name="name">HR Manager</field><field name="category_id" ref="category_human_resources"/><field name="implied_ids" eval="[(4, ref('group_hr_user'))]"/>
    </record>
</odoo>
