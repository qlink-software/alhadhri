        </record>
        <record id="category_client_files" model="ir.module.category">
            <field name="name">Client Files</field>
            <field name="parent_id" ref="qlk_management.qlk_management_manage_category"/>
            <field name="sequence" eval="30"/>
        </record>
        <record id="category_legal_projects" model="ir.module.category">
            <field name="name">Legal Projects</field>
            <field name="parent_id" ref="qlk_management.qlk_management_manage_category"/>
