            <field name="name">Special Permissions</field>
            <field name="parent_id" ref="qlk_management.qlk_management_manage_category"/>
            <field name="sequence" eval="70"/>
        </record>
        <record id="group_bd_user" model="res.groups">
            <field name="name">Business Development User</field>
            <field name="category_id" ref="qlk_management.category_business_development"/>
