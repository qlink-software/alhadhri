<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="qlk_management_manage_category" model="ir.module.category">
            <field name="name">Alhadhri Access Rights</field>
            <field name="sequence" eval="55"/>
        </record>
        <record id="category_business_development" model="ir.module.category">
