<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Project permissions / صلاحيات المشاريع -->
    <record id="category_legal_projects" model="ir.module.category">
        <field name="name">Projects</field><field name="parent_id" ref="qlk_management_manage_category"/><field name="sequence" eval="40"/>
    </record>
    <record id="group_project_user" model="res.groups">
        <field name="name">Project User</field><field name="category_id" ref="category_legal_projects"/><field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('project.group_project_user'))]"/>
    </record>
    <record id="group_project_manager" model="res.groups">
        <field name="name">Project Manager</field><field name="category_id" ref="category_legal_projects"/><field name="implied_ids" eval="[(4, ref('group_project_user')), (4, ref('project.group_project_manager'))]"/>
    </record>
</odoo>
