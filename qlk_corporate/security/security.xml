<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="qlk_management_corporate_category" model="ir.module.category">
            <field name="name">Corporate Category</field>
            <field name="sequence" eval="65"/>
        </record>
        <record id="group_corporate_user" model="res.groups">
            <field name="name">Corporate User</field>
            <field name="category_id" ref="qlk_corporate.qlk_management_corporate_category"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_corporate_manager" model="res.groups">
            <field name="name">Corporate Manager</field>
            <field name="category_id" ref="qlk_corporate.qlk_management_corporate_category"/>
            <field name="implied_ids" eval="[(4, ref('qlk_corporate.group_corporate_user'))]"/>
        </record>
    </data>
</odoo>
