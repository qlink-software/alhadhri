<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="rule_qlk_task_user" model="ir.rule">
            <field name="name">Task &amp; Hours Entry User</field>
            <field name="model_id" ref="model_qlk_task"/>
            <field name="domain_force">['|', ('assigned_user_id', '=', user.id), ('reviewer_id', '=', user.id)]</field>
            <field name="groups" eval="[(6, 0, [ref('qlk_task_management.group_task_user')])]"/>
        </record>
        <record id="rule_qlk_task_manager" model="ir.rule">
            <field name="name">Task &amp; Hours Entry Manager</field>
            <field name="model_id" ref="model_qlk_task"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(6, 0, [ref('qlk_task_management.group_task_manager')])]"/>
        </record>
    </data>
</odoo>
