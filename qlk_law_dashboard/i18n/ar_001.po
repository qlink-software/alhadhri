#. module: qlk_law_dashboard
#. odoo-python
#: code:addons/qlk_law_dashboard/models/assignment_notifications.py:0
msgid ""
"\n"
"                <p>Dear Lawyer,</p>\n"
"                <p>A hearing has been assigned to you.</p>\n"
"                <p><b>Hearing:</b> %(hearing)s<br/>\n"
"                <b>Date:</b> %(date)s<br/>\n"
"                <b>Case:</b> %(case)s<br/>\n"
"                <b>Client:</b> %(client)s</p>\n"
"                <p>Please review the hearing details.</p>\n"
"                <p>Regards,<br/>Al Hadhri &amp; Partners</p>\n"
"                "
msgstr ""
"\n"
"                <p>عزيزي المحامي,</p>\n"
"                <p>تم إسناد جلسة إليك.</p>\n"
"                <p><b>الجلسة:</b> %(hearing)s<br/>\n"
"                <b>التاريخ:</b> %(date)s<br/>\n"
"                <b>Case:</b> %(case)s<br/>\n"
"                <b>العميل:</b> %(client)s</p>\n"
"                <p>يرجى مراجعة تفاصيل الجلسة.</p>\n"
"                <p>مع التحية,<br/>الحاضري وشركاؤه</p>\n"
"                "

#. module: qlk_law_dashboard
#. odoo-python
#: code:addons/qlk_law_dashboard/models/assignment_notifications.py:0
msgid ""
"\n"
"                <p>Dear Lawyer,</p>\n"
"                <p>A new case has been created and assigned to you.</p>\n"
"                <p><b>Case Number:</b> %(case_number)s<br/>\n"
"                <b>Project:</b> %(project)s<br/>\n"
"                <b>Client:</b> %(client)s<br/>\n"
"                <b>Case Type:</b> %(case_type)s<br/>\n"
"                <b>Degree:</b> %(degree)s</p>\n"
"                <p>Please review the case immediately.</p>\n"
"                <p>Regards,<br/>Al Hadhri &amp; Partners</p>\n"
"                "
msgstr ""
"\n"
"                <p>عزيزي المحامي,</p>\n"
"                <p>تم إنشاء قضية جديدة وإسنادها إليك.</p>\n"
"                <p><b>رقم القضية:</b> %(case_number)s<br/>\n"
"                <b>المشروع:</b> %(project)s<br/>\n"
"                <b>العميل:</b> %(client)s<br/>\n"
"                <b>نوع القضية:</b> %(case_type)s<br/>\n"
"                <b>الدرجة:</b> %(degree)s</p>\n"
"                <p>يرجى مراجعة القضية فورًا.</p>\n"
"                <p>مع التحية,<br/>الحاضري وشركاؤه</p>\n"
"                "

#. module: qlk_law_dashboard
#. odoo-python
#: code:addons/qlk_law_dashboard/models/assignment_notifications.py:0
msgid ""
"\n"
"                <p>Dear Lawyer,</p>\n"
"                <p>A new project has been assigned to you.</p>\n"
"                <p><b>Service Code:</b> %(code)s<br/>\n"
"                <b>Client:</b> %(client)s<br/>\n"
"                <b>Project:</b> %(project)s<br/>\n"
"                <b>Project Type:</b> %(project_type)s<br/>\n"
"                <b>Assigned By:</b> %(assigned_by)s<br/>\n"
"                <b>Date:</b> %(date)s</p>\n"
"                <p>Please review and start working on the project.</p>\n"
"                <p>Regards,<br/>Al Hadhri &amp; Partners</p>\n"
"                "
msgstr ""
"\n"
"                <p>عزيزي المحامي,</p>\n"
"                <p>تم إسناد مشروع جديد إليك.</p>\n"
"                <p><b>رمز الخدمة:</b> %(code)s<br/>\n"
"                <b>العميل:</b> %(client)s<br/>\n"
"                <b>المشروع:</b> %(project)s<br/>\n"
"                <b>نوع المشروع:</b> %(project_type)s<br/>\n"
"                <b>أُسند بواسطة:</b> %(assigned_by)s<br/>\n"
"                <b>التاريخ:</b> %(date)s</p>\n"
"                <p>يرجى مراجعة المشروع وبدء العمل عليه.</p>\n"
"                <p>مع التحية,<br/>الحاضري وشركاؤه</p>\n"
"                "

#. module: qlk_law_dashboard
#. odoo-python
#: code:addons/qlk_law_dashboard/models/assignment_notifications.py:0
msgid ""
"\n"
"                <p>Dear Lawyer,</p>\n"
"                <p>A new task has been assigned to you.</p>\n"
"                <p><b>Task:</b> %(task)s<br/>\n"
"                <b>Project:</b> %(project)s<br/>\n"
"                <b>Deadline:</b> %(deadline)s<br/>\n"
"                <b>Assigned By:</b> %(assigned_by)s</p>\n"
"                <p>Regards,<br/>Al Hadhri &amp; Partners</p>\n"
"                "
msgstr ""
"\n"
"                <p>عزيزي المحامي,</p>\n"
"                <p>تم إسناد مهمة جديدة إليك.</p>\n"
"                <p><b>المهمة:</b> %(task)s<br/>\n"
"                <b>المشروع:</b> %(project)s<br/>\n"
"                <b>الموعد النهائي:</b> %(deadline)s<br/>\n"
"                <b>أُسند بواسطة:</b> %(assigned_by)s</p>\n"
"                <p>مع التحية,<br/>الحاضري وشركاؤه</p>\n"
"                "

#. module: qlk_law_dashboard
#. odoo-python
#: code:addons/qlk_law_dashboard/models/lawyer_notification.py:0
msgid ""
"\n"
"                <p>Dear Lawyer,</p>\n"
"                <p>Today's assigned work summary:</p>\n"
"                <ul>\n"
"                    <li>Projects assigned today: %(projects)s</li>\n"
"                    <li>Cases assigned today: %(cases)s</li>\n"
"                    <li>Hearings today: %(hearings)s</li>\n"
"                    <li>Tasks due today: %(tasks)s</li>\n"
"                </ul>\n"
"                <p>Regards,<br/>Al Hadhri &amp; Partners</p>\n"
"                "
msgstr ""
"\n"
"                <p>عزيزي المحامي,</p>\n"
"                <p>ملخص الأعمال المسندة اليوم:</p>\n"
"                <ul>\n"
"                    <li>المشاريع المسندة اليوم: %(projects)s</li>\n"
"                    <li>القضايا المسندة اليوم: %(cases)s</li>\n"
"                    <li>جلسات اليوم: %(hearings)s</li>\n"
"                    <li>المهام المستحقة اليوم: %(tasks)s</li>\n"
"                </ul>\n"
"                <p>مع التحية,<br/>الحاضري وشركاؤه</p>\n"
"                "

