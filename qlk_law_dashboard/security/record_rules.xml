<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="rule_qlk_lawyer_notification_own" model="ir.rule">
            <field name="name">Lawyer Notification - Own Records</field>
            <field name="model_id" ref="model_qlk_lawyer_notification"/>
            <field name="groups" eval="[
                (4, ref('qlk_law_dashboard.group_qlk_law_dashboard_user')),
                (4, ref('qlk_law.group_qlk_law_lawyer'))
            ]"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
        </record>
        <record id="rule_qlk_lawyer_notification_manager" model="ir.rule">
            <field name="name">Lawyer Notification - Manager</field>
            <field name="model_id" ref="model_qlk_lawyer_notification"/>
            <field name="groups" eval="[(4, ref('qlk_law_dashboard.group_qlk_law_dashboard_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>
    </data>
</odoo>
