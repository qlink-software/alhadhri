<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="qlk_management_law_dashboard_category" model="ir.module.category">
            <field name="name">Law Dashboard Category</field>
            <field name="sequence" eval="80"/>
        </record>
        <record id="group_qlk_law_dashboard_user" model="res.groups">
            <field name="name">Law Dashboard User</field>
            <field name="category_id" ref="qlk_law_dashboard.qlk_management_law_dashboard_category"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_qlk_law_dashboard_manager" model="res.groups">
            <field name="name">Law Dashboard Manager</field>
            <field name="category_id" ref="qlk_law_dashboard.qlk_management_law_dashboard_category"/>
            <field name="implied_ids" eval="[(4, ref('qlk_law_dashboard.group_qlk_law_dashboard_user'))]"/>
        </record>
    </data>
</odoo>
