<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_employee_form_inherit_monthly_hours_target" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.monthly.hours.target</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Performance">
                    <field name="monthly_hours_target"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
