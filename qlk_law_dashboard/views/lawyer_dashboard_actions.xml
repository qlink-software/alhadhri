<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_law_dashboard_corporate_matters" model="ir.actions.act_window">
        <field name="name">Corporate Matters</field>
        <field name="res_model">qlk.project</field>
        <field name="view_mode">list,form</field>
        <field name="domain">['&amp;', ('active', '=', True), '|', ('service_category', '=', 'corporate'), ('service_type', '=', 'corporate')]</field>
        <field name="search_view_id" ref="qlk_management.view_qlk_project_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No corporate matters found.
            </p>
        </field>
    </record>

    <record id="action_law_dashboard_arbitration_matters" model="ir.actions.act_window">
        <field name="name">Arbitration Matters</field>
        <field name="res_model">qlk.project</field>
        <field name="view_mode">list,form</field>
        <field name="domain">['&amp;', ('active', '=', True), '|', ('service_category', '=', 'arbitration'), ('service_type', '=', 'arbitration')]</field>
        <field name="search_view_id" ref="qlk_management.view_qlk_project_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No arbitration matters found.
            </p>
        </field>
    </record>
</odoo>
