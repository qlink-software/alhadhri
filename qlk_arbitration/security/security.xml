<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="qlk_management_arbitration_category" model="ir.module.category">
            <field name="name">Arbitrations Category</field>
            <field name="sequence" eval="60"/>
        </record>
        <record id="group_arbitration_user" model="res.groups">
            <field name="name">Arbitration User</field>
            <field name="category_id" ref="qlk_arbitration.qlk_management_arbitration_category"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>
        <record id="group_arbitration_manager" model="res.groups">
            <field name="name">Arbitration Manager</field>
            <field name="category_id" ref="qlk_arbitration.qlk_management_arbitration_category"/>
            <field name="implied_ids" eval="[(4, ref('qlk_arbitration.group_arbitration_user'))]"/>
        </record>
    </data>
</odoo>
