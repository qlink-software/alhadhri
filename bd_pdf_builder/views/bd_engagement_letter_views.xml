<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_bd_engagement_pdf_builder" model="ir.ui.view">
            <field name="name">bd.engagement.letter.form.report.button</field>
            <field name="model">bd.engagement.letter</field>
            <field name="inherit_id" ref="qlk_management.view_bd_engagement_letter_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form/header" position="inside">
                    <button name="action_print_engagement_pdf"
                            type="object"
                            string="Print Engagement Letter PDF"
                            class="btn-secondary"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
