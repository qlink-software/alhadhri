<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_proposal_pdf">
        <t t-name="bd_pdf_builder.report_proposal_pdf">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-set="bd_company" t-value="doc.company_id"/>
                    <t t-set="bd_title_ar" t-value="'عرض خدمات قانونية'"/>
                    <t t-set="bd_title_en" t-value="'Legal Services Proposal'"/>
                    <t t-set="bd_info_reference" t-value="doc.code or doc.name or ''"/>
                    <t t-set="bd_info_date" t-value="doc.date and doc.date.strftime('%d/%m/%Y') or ''"/>
                    <t t-set="bd_info_client" t-value="doc.partner_id.display_name or doc.client_id.display_name or ''"/>
                    <t t-set="bd_info_prepared_by" t-value="doc.reviewer_id.name or doc.create_uid.name or ''"/>
                    <t t-set="bd_signature_prepared_by" t-value="doc.create_uid.name or ''"/>
                    <t t-set="bd_signature_prepared_position" t-value="'Business Development'"/>
                    <t t-set="bd_signature_reviewed_by" t-value="doc.reviewer_id.name or ''"/>
                    <t t-set="bd_signature_reviewed_position" t-value="'Reviewer'"/>
                    <t t-set="bd_signature_approved_by" t-value="doc.approved_by.name or ''"/>
                    <t t-set="bd_signature_approved_position" t-value="'Approver'"/>
                    <t t-set="bd_signature_client" t-value="doc.partner_id.display_name or doc.client_id.display_name or ''"/>
                    <t t-set="bd_signature_date" t-value="doc.date and doc.date.strftime('%d/%m/%Y') or ''"/>
                    <t t-set="currency_name" t-value="doc.currency_id.symbol or doc.currency_id.name or ''"/>
                    <t t-set="fee_total" t-value="doc.total_legal_fees or doc.total_amount or doc.legal_fees or 0.0"/>
                    <t t-set="image_attachments" t-value="doc._get_report_image_attachments()"/>

                    <t t-call="bd_pdf_builder.report_layout_standard">
                        <div class="bd-section">
                            <div class="bd-section-header">Client &amp; Proposal Information</div>
                            <div class="bd-section-body">
                                <table class="bd-kv-table">
                                    <tr>
                                        <th>Client</th>
                                        <td><t t-esc="doc.partner_id.display_name or doc.client_id.display_name or '-'"/></td>
                                        <th>Proposal Type</th>
                                        <td><t t-esc="dict(doc._fields['proposal_type'].selection).get(doc.proposal_type, doc.proposal_type or '-')"/></td>
                                    </tr>
                                    <tr>
                                        <th>Service Type</th>
                                        <td><t t-esc="dict(doc._fields['retainer_type'].selection).get(doc.retainer_type, doc.retainer_type or '-')"/></td>
                                        <th>Billing Type</th>
                                        <td><t t-esc="dict(doc._fields['billing_type'].selection).get(doc.billing_type, doc.billing_type or '-')"/></td>
                                    </tr>
                                    <tr>
                                        <th>Assigned Lawyer</th>
                                        <td><t t-esc="doc.lawyer_employee_id.name or doc.lawyer_id.display_name or '-'"/></td>
                                        <th>Client Code</th>
                                        <td><t t-esc="doc.client_code or '-'"/></td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <div class="bd-section">
                            <div class="bd-section-header">Scope of Work</div>
                            <div class="bd-section-body">
                                <div class="bd-pre" t-esc="doc.scope_of_work or doc.services_description or '-'"/>
                            </div>
                        </div>

                        <div class="bd-section">
                            <div class="bd-section-header">Fees</div>
                            <div class="bd-section-body">
                                <t t-if="doc.billing_type == 'free'">
                                    <p>This proposal is marked as pro bono and does not carry billable legal fees.</p>
                                </t>
                                <t t-if="doc.billing_type != 'free'">
                                    <table class="bd-table">
                                        <thead>
                                            <tr>
                                                <th>Service</th>
                                                <th>Service Type</th>
                                                <th>Qty</th>
                                                <th>Unit Price</th>
                                                <th>Discount</th>
                                                <th>Subtotal</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr t-foreach="doc.legal_fees_lines" t-as="line">
                                                <td><t t-esc="line.service_name or line.description or '-'"/></td>
                                                <td><span t-if="line.service_type" t-field="line.service_type"/><span t-if="not line.service_type">-</span></td>
                                                <td class="bd-number"><t t-esc="'{:,.2f}'.format(line.quantity or 0.0)"/></td>
                                                <td class="bd-number"><t t-esc="'{:,.3f}'.format(line.unit_price or 0.0)"/> <t t-esc="currency_name"/></td>
                                                <td class="bd-number">
                                                    <t t-if="line.discount_type == 'percent'"><t t-esc="'{:,.2f}'.format(line.discount or 0.0)"/>%</t>
                                                    <t t-else=""><t t-esc="'{:,.3f}'.format(line.discount or 0.0)"/> <t t-esc="currency_name"/></t>
                                                </td>
                                                <td class="bd-number"><t t-esc="'{:,.3f}'.format(line.subtotal or line.amount or 0.0)"/> <t t-esc="currency_name"/></td>
                                            </tr>
                                            <tr t-if="not doc.legal_fees_lines">
                                                <td>Legal Fees</td>
                                                <td>-</td>
                                                <td class="bd-number">1.00</td>
                                                <td class="bd-number"><t t-esc="'{:,.3f}'.format(fee_total or 0.0)"/> <t t-esc="currency_name"/></td>
                                                <td class="bd-number">0.00</td>
                                                <td class="bd-number"><t t-esc="'{:,.3f}'.format(fee_total or 0.0)"/> <t t-esc="currency_name"/></td>
                                            </tr>
                                            <tr class="bd-total-row">
                                                <td colspan="5">Total Legal Fees</td>
                                                <td class="bd-number"><t t-esc="'{:,.3f}'.format(fee_total or 0.0)"/> <t t-esc="currency_name"/></td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </t>
                            </div>
                        </div>

                        <div class="bd-section" t-if="doc.payment_terms or doc.terms_conditions">
                            <div class="bd-section-header">Payment Terms &amp; Conditions</div>
                            <div class="bd-section-body">
                                <p t-if="doc.payment_terms"><strong>Payment Terms: </strong><t t-esc="doc.payment_terms"/></p>
                                <div t-if="doc.terms_conditions" t-field="doc.terms_conditions"/>
                            </div>
                        </div>

                        <div class="bd-section" t-if="image_attachments">
                            <div class="bd-section-header">Attachments</div>
                            <div class="bd-section-body">
                                <table class="bd-table">
                                    <thead>
                                        <tr>
                                            <th>Attachment</th>
                                            <th>Type</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="image_attachments" t-as="attachment">
                                            <td><t t-esc="attachment.name or 'Attachment'"/></td>
                                            <td><t t-esc="attachment.mimetype or '-'"/></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <t t-call="bd_pdf_builder.standard_signature_table"/>
                    </t>
                </t>
            </t>
        </t>
    </template>
</odoo>
