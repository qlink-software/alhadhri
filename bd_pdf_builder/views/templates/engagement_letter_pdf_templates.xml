<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_engagement_letter_pdf">
        <t t-name="bd_pdf_builder.report_engagement_letter_pdf">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-set="bd_company" t-value="doc.company_id"/>
                    <t t-set="bd_title_ar" t-value="'إتفاقية أتعاب'"/>
                    <t t-set="bd_title_en" t-value="'Mandate Agreement'"/>
                    <t t-set="bd_info_reference" t-value="doc.reference or doc.code or ''"/>
                    <t t-set="bd_info_date" t-value="doc.date and doc.date.strftime('%d/%m/%Y') or ''"/>
                    <t t-set="bd_info_client" t-value="doc.partner_id.display_name or doc.client_id.display_name or ''"/>
                    <t t-set="bd_info_prepared_by" t-value="doc.reviewer_id.name or doc.create_uid.name or ''"/>
                    <t t-set="bd_signature_prepared_by" t-value="doc.create_uid.name or ''"/>
                    <t t-set="bd_signature_prepared_position" t-value="'Business Development'"/>
                    <t t-set="bd_signature_reviewed_by" t-value="doc.reviewer_id.name or ''"/>
                    <t t-set="bd_signature_reviewed_position" t-value="'Reviewer'"/>
                    <t t-set="bd_signature_approved_by" t-value="doc.approved_by.name or ''"/>
                    <t t-set="bd_signature_approved_position" t-value="'Approver'"/>
                    <t t-set="bd_signature_client" t-value="doc.partner_id.display_name or doc.client_id.display_name or ''"/>
                    <t t-set="bd_signature_date" t-value="doc.date and doc.date.strftime('%d/%m/%Y') or ''"/>
                    <t t-set="partner_name" t-value="doc.partner_id.display_name or doc.client_id.display_name or ''"/>
                    <t t-set="partner_id_no" t-value="doc.partner_id.vat or doc.partner_id.ref or ''"/>
                    <t t-set="partner_phone" t-value="doc.partner_id.mobile or doc.partner_id.phone or ''"/>
                    <t t-set="partner_email" t-value="doc.partner_id.email or ''"/>
                    <t t-set="partner_address" t-value="doc.contact_details or doc.partner_id.contact_address or ''"/>
                    <t t-set="currency_name" t-value="doc.currency_id.symbol or doc.currency_id.name or ''"/>
                    <t t-set="fee_total" t-value="doc.total_legal_fees or doc.fee_total or doc.total_amount or doc.legal_fee_amount or 0.0"/>

                    <t t-call="bd_pdf_builder.report_layout_standard">
                        <div class="bd-section">
                            <div class="bd-section-header">Parties</div>
                            <div class="bd-section-body">
                                <table class="bd-bilingual-table">
                                    <tr>
                                        <th class="bd-ar" lang="ar" dir="rtl">الأطراف</th>
                                        <th class="bd-en" lang="en" dir="ltr">Parties</th>
                                    </tr>
                                    <tr>
                                        <td class="bd-ar" lang="ar" dir="rtl">
                                            <p><strong>أولاً:</strong> الحضري وشركاه للمحاماة، رخصة المكتب رقم (212506)، برج البراحة، الطابق الخامس، لوسيل مارينا، ص.ب 18022، الدوحة، قطر.</p>
                                            <p>ويمثله المحامي عبد الله الحضري بصفته الشريك المدير، ويشار إليه فيما بعد بـ "الطرف الأول".</p>
                                        </td>
                                        <td class="bd-en" lang="en" dir="ltr">
                                            <p><strong>First:</strong> Al Hadhri &amp; Partners Law Firm, office license No. (212506), Al Baraha Tower, 5th Floor, Lusail Marina, P.O. Box 18022, Doha, Qatar.</p>
                                            <p>Represented by Lawyer Abdalla Al-Hadhri in his capacity as Managing Partner, hereinafter the "First Party".</p>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="bd-ar" lang="ar" dir="rtl">
                                            <p><strong>ثانياً:</strong> <t t-esc="partner_name or '-'"/></p>
                                            <p>بطاقة شخصية / سجل تجاري رقم: <t t-esc="partner_id_no or '-'"/></p>
                                            <p>هاتف: <t t-esc="partner_phone or '-'"/>، بريد إلكتروني: <t t-esc="partner_email or '-'"/></p>
                                            <p t-if="partner_address">العنوان / ص.ب: <span class="bd-pre" t-esc="partner_address"/></p>
                                            <p>ويشار إليه فيما بعد بـ "الطرف الثاني".</p>
                                        </td>
                                        <td class="bd-en" lang="en" dir="ltr">
                                            <p><strong>Second:</strong> <t t-esc="partner_name or '-'"/></p>
                                            <p>ID / CR Number: <t t-esc="partner_id_no or '-'"/></p>
                                            <p>Phone: <t t-esc="partner_phone or '-'"/>, Email: <t t-esc="partner_email or '-'"/></p>
                                            <p t-if="partner_address">Address / P.O. Box: <span class="bd-pre" t-esc="partner_address"/></p>
                                            <p>Hereinafter the "Second Party".</p>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <div class="bd-section">
                            <div class="bd-section-header">Scope of Work</div>
                            <div class="bd-section-body">
                                <table class="bd-bilingual-table">
                                    <tr>
                                        <th class="bd-ar" lang="ar" dir="rtl">نطاق الأعمال</th>
                                        <th class="bd-en" lang="en" dir="ltr">Scope of Work</th>
                                    </tr>
                                    <tr>
                                        <td class="bd-ar" lang="ar" dir="rtl"><div class="bd-pre" t-esc="doc.scope_of_work or doc.services_description or '-'"/></td>
                                        <td class="bd-en" lang="en" dir="ltr"><div class="bd-pre" t-esc="doc.scope_of_work or doc.services_description or '-'"/></td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <div class="bd-section">
                            <div class="bd-section-header">Fees</div>
                            <div class="bd-section-body">
                                <table class="bd-bilingual-table">
                                    <tr>
                                        <th class="bd-ar" lang="ar" dir="rtl">الأتعاب</th>
                                        <th class="bd-en" lang="en" dir="ltr">Fees</th>
                                    </tr>
                                    <tr>
                                        <td class="bd-ar" lang="ar" dir="rtl">
                                            <p>تكون أتعاب الطرف الأول مقابل تقديم الخدمات القانونية وفقاً لنطاق العمل مبلغ <strong><t t-esc="'{:,.3f}'.format(fee_total or 0.0)"/> <t t-esc="currency_name"/></strong>.</p>
                                            <p t-if="doc.payment_terms">شروط السداد: <t t-esc="doc.payment_terms"/></p>
                                        </td>
                                        <td class="bd-en" lang="en" dir="ltr">
                                            <p>The First Party's legal fees for the scope of work shall be <strong><t t-esc="'{:,.3f}'.format(fee_total or 0.0)"/> <t t-esc="currency_name"/></strong>.</p>
                                            <p t-if="doc.payment_terms">Payment Terms: <t t-esc="doc.payment_terms"/></p>
                                        </td>
                                    </tr>
                                </table>
                                <table class="bd-table">
                                    <thead>
                                        <tr>
                                            <th>Service</th>
                                            <th>Type</th>
                                            <th>Qty</th>
                                            <th>Unit Price</th>
                                            <th>Discount</th>
                                            <th>Subtotal</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="doc.legal_fees_lines" t-as="line">
                                            <td><t t-esc="line.service_name or line.description or '-'"/></td>
                                            <td><span t-if="line.service_type" t-field="line.service_type"/><span t-if="not line.service_type">-</span></td>
                                            <td class="bd-number"><t t-esc="'{:,.2f}'.format(line.quantity or 0.0)"/></td>
                                            <td class="bd-number"><t t-esc="'{:,.3f}'.format(line.unit_price or 0.0)"/> <t t-esc="currency_name"/></td>
                                            <td class="bd-number">
                                                <t t-if="line.discount_type == 'percent'"><t t-esc="'{:,.2f}'.format(line.discount or 0.0)"/>%</t>
                                                <t t-else=""><t t-esc="'{:,.3f}'.format(line.discount or 0.0)"/> <t t-esc="currency_name"/></t>
                                            </td>
                                            <td class="bd-number"><t t-esc="'{:,.3f}'.format(line.subtotal or line.amount or 0.0)"/> <t t-esc="currency_name"/></td>
                                        </tr>
                                        <tr t-if="not doc.legal_fees_lines">
                                            <td>Legal Fees</td>
                                            <td>-</td>
                                            <td class="bd-number">1.00</td>
                                            <td class="bd-number"><t t-esc="'{:,.3f}'.format(fee_total or 0.0)"/> <t t-esc="currency_name"/></td>
                                            <td class="bd-number">0.00</td>
                                            <td class="bd-number"><t t-esc="'{:,.3f}'.format(fee_total or 0.0)"/> <t t-esc="currency_name"/></td>
                                        </tr>
                                        <tr class="bd-total-row">
                                            <td colspan="5">Total Legal Fees</td>
                                            <td class="bd-number"><t t-esc="'{:,.3f}'.format(fee_total or 0.0)"/> <t t-esc="currency_name"/></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <div class="bd-section">
                            <div class="bd-section-header">Terms and Provisions Addendum</div>
                            <div class="bd-section-body">
                                <table class="bd-bilingual-table">
                                    <tr>
                                        <th class="bd-ar" lang="ar" dir="rtl">الشروط والأحكام</th>
                                        <th class="bd-en" lang="en" dir="ltr">Terms and Provisions</th>
                                    </tr>
                                    <tr>
                                        <td class="bd-ar" lang="ar" dir="rtl">
                                            <ol class="bd-terms-list">
                                                <li>تعتبر المقدمة ونطاق العمل جزءاً لا يتجزأ من هذه الاتفاقية.</li>
                                                <li>يلتزم الطرف الثاني بتزويد الطرف الأول بكافة المستندات والمعلومات اللازمة فور طلبها.</li>
                                                <li>يلتزم الطرف الأول ببذل العناية المهنية اللازمة ولا يضمن نتيجة محددة.</li>
                                                <li>تستحق الأتعاب وفق شروط السداد المتفق عليها، وللطرف الأول التوقف عن العمل عند التأخر في السداد.</li>
                                                <li>يحافظ الطرفان على سرية المعلومات المتبادلة بموجب هذه الاتفاقية.</li>
                                                <li>تخضع هذه الاتفاقية لقوانين دولة قطر وتختص المحاكم القطرية بأي نزاع ينشأ عنها.</li>
                                            </ol>
                                        </td>
                                        <td class="bd-en" lang="en" dir="ltr">
                                            <ol class="bd-terms-list">
                                                <li>The preamble and scope of work form an integral part of this Agreement.</li>
                                                <li>The Second Party shall provide all documents and information required by the First Party upon request.</li>
                                                <li>The First Party undertakes to exercise professional due care and does not guarantee a specific result.</li>
                                                <li>Fees are payable in accordance with the agreed payment terms, and the First Party may suspend work for delayed payment.</li>
                                                <li>Both parties shall keep exchanged information confidential.</li>
                                                <li>This Agreement is governed by the laws of the State of Qatar, and Qatari courts shall have jurisdiction.</li>
                                            </ol>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <t t-call="bd_pdf_builder.standard_signature_table"/>
                    </t>
                </t>
            </t>
        </t>
    </template>
</odoo>
