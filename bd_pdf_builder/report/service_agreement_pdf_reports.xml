<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_corporate_service_agreement_pdf">
        <t t-name="bd_pdf_builder.report_corporate_service_agreement_pdf">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-set="bd_agreement_kind" t-value="'corporate'"/>
                    <t t-set="bd_title_ar" t-value="'اتفاقية خدمات الشركات'"/>
                    <t t-set="bd_title_en" t-value="'Corporate Service Agreement'"/>
                    <t t-set="bd_agreement_subject_ar" t-value="'خدمات الشركات والاستشارات التجارية'"/>
                    <t t-set="bd_agreement_subject_en" t-value="'Corporate and commercial advisory services'"/>
                    <t t-call="bd_pdf_builder.service_agreement_document"/>
                </t>
            </t>
        </t>
    </template>

    <template id="report_litigation_service_agreement_pdf">
        <t t-name="bd_pdf_builder.report_litigation_service_agreement_pdf">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-set="bd_agreement_kind" t-value="'litigation'"/>
                    <t t-set="bd_title_ar" t-value="'اتفاقية خدمات التقاضي'"/>
                    <t t-set="bd_title_en" t-value="'Litigation Service Agreement'"/>
                    <t t-set="bd_agreement_subject_ar" t-value="'التمثيل القضائي وإدارة المنازعات'"/>
                    <t t-set="bd_agreement_subject_en" t-value="'Court representation and dispute management'"/>
                    <t t-call="bd_pdf_builder.service_agreement_document"/>
                </t>
            </t>
        </t>
    </template>

    <template id="report_arbitration_service_agreement_pdf">
        <t t-name="bd_pdf_builder.report_arbitration_service_agreement_pdf">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-set="bd_agreement_kind" t-value="'arbitration'"/>
                    <t t-set="bd_title_ar" t-value="'اتفاقية خدمات التحكيم'"/>
                    <t t-set="bd_title_en" t-value="'Arbitration Service Agreement'"/>
                    <t t-set="bd_agreement_subject_ar" t-value="'إدارة وتمثيل قضايا التحكيم'"/>
                    <t t-set="bd_agreement_subject_en" t-value="'Arbitration case management and representation'"/>
                    <t t-call="bd_pdf_builder.service_agreement_document"/>
                </t>
            </t>
        </t>
    </template>

    <template id="service_agreement_document" name="BD Service Agreement Document">
        <t t-set="bd_company" t-value="doc.company_id"/>
        <t t-set="bd_info_reference" t-value="doc.reference or doc.code or ''"/>
        <t t-set="bd_info_date" t-value="doc.date and doc.date.strftime('%d/%m/%Y') or ''"/>
        <t t-set="bd_info_client" t-value="doc.partner_id.display_name or doc.client_id.display_name or ''"/>
        <t t-set="bd_info_prepared_by" t-value="doc.reviewer_id.name or doc.create_uid.name or ''"/>
        <t t-set="bd_signature_prepared_by" t-value="doc.create_uid.name or ''"/>
        <t t-set="bd_signature_prepared_position" t-value="'Business Development'"/>
        <t t-set="bd_signature_reviewed_by" t-value="doc.reviewer_id.name or ''"/>
        <t t-set="bd_signature_reviewed_position" t-value="'Reviewer'"/>
        <t t-set="bd_signature_approved_by" t-value="doc.approved_by.name or ''"/>
        <t t-set="bd_signature_approved_position" t-value="'Approver'"/>
        <t t-set="bd_signature_client" t-value="doc.partner_id.display_name or doc.client_id.display_name or ''"/>
        <t t-set="bd_signature_date" t-value="doc.date and doc.date.strftime('%d/%m/%Y') or ''"/>
        <t t-set="currency_name" t-value="doc.currency_id.symbol or doc.currency_id.name or ''"/>
        <t t-set="fee_total" t-value="doc.total_legal_fees or doc.fee_total or doc.total_amount or doc.legal_fee_amount or 0.0"/>
        <t t-set="client_name" t-value="doc.partner_id.display_name or doc.client_id.display_name or ''"/>
        <t t-set="services_summary" t-value="', '.join(doc.legal_service_type_ids.mapped('name')) if doc.legal_service_type_ids else dict(doc._fields['service_type'].selection).get(doc.service_type, doc.service_type or '')"/>

        <t t-call="bd_pdf_builder.report_layout_standard">
            <div class="bd-section">
                <div class="bd-section-header">Agreement Overview</div>
                <div class="bd-section-body">
                    <table class="bd-bilingual-table">
                        <tr>
                            <th class="bd-ar" lang="ar" dir="rtl">موضوع الاتفاقية</th>
                            <th class="bd-en" lang="en" dir="ltr">Agreement Subject</th>
                        </tr>
                        <tr>
                            <td class="bd-ar" lang="ar" dir="rtl">
                                <p>أبرمت هذه الاتفاقية بين الحضري وشركاه للمحاماة وبين <strong><t t-esc="client_name or '-'"/></strong> بشأن <strong><t t-esc="bd_agreement_subject_ar"/></strong>.</p>
                                <p>يشمل نطاق الخدمات ما يتم اعتماده في هذه الاتفاقية وأي تعليمات كتابية لاحقة بين الطرفين.</p>
                            </td>
                            <td class="bd-en" lang="en" dir="ltr">
                                <p>This Agreement is entered into between Al Hadhri &amp; Partners Law Firm and <strong><t t-esc="client_name or '-'"/></strong> for <strong><t t-esc="bd_agreement_subject_en"/></strong>.</p>
                                <p>The scope includes the services approved in this Agreement and any subsequent written instructions agreed by the parties.</p>
                            </td>
                        </tr>
                    </table>
                </div>
            </div>

            <div class="bd-section">
                <div class="bd-section-header">Client &amp; Service Information</div>
                <div class="bd-section-body">
                    <table class="bd-kv-table">
                        <tr>
                            <th>Client</th>
                            <td><t t-esc="client_name or '-'"/></td>
                            <th>Client Code</th>
                            <td><t t-esc="doc.client_code or '-'"/></td>
                        </tr>
                        <tr>
                            <th>Service Category</th>
                            <td><t t-esc="services_summary or '-'"/></td>
                            <th>Contract Type</th>
                            <td><t t-esc="dict(doc._fields['contract_type'].selection).get(doc.contract_type, doc.contract_type or '-')"/></td>
                        </tr>
                        <tr>
                            <th>Assigned Lawyer</th>
                            <td><t t-esc="doc.lawyer_employee_id.name or doc.lawyer_id.display_name or '-'"/></td>
                            <th>Billing Type</th>
                            <td><t t-esc="dict(doc._fields['billing_type'].selection).get(doc.billing_type, doc.billing_type or '-')"/></td>
                        </tr>
                    </table>
                </div>
            </div>

            <div class="bd-section">
                <div class="bd-section-header">Scope of Services</div>
                <div class="bd-section-body">
                    <table class="bd-bilingual-table">
                        <tr>
                            <th class="bd-ar" lang="ar" dir="rtl">نطاق الخدمات</th>
                            <th class="bd-en" lang="en" dir="ltr">Scope of Services</th>
                        </tr>
                        <tr>
                            <td class="bd-ar" lang="ar" dir="rtl">
                                <div class="bd-pre" t-esc="doc.scope_of_work or doc.services_description or '-'"/>
                                <ul class="bd-terms-list" t-if="bd_agreement_kind == 'corporate'">
                                    <li>تقديم الاستشارات القانونية المتعلقة بالشركات والمعاملات التجارية.</li>
                                    <li>مراجعة وصياغة المستندات والعقود التجارية.</li>
                                    <li>دعم إجراءات الجهات الحكومية ذات الصلة ضمن النطاق المتفق عليه.</li>
                                </ul>
                                <ul class="bd-terms-list" t-if="bd_agreement_kind == 'litigation'">
                                    <li>دراسة النزاع وإعداد المذكرات والمرافعات اللازمة.</li>
                                    <li>تمثيل العميل أمام المحاكم والجهات المختصة وفق التفويض.</li>
                                    <li>متابعة الجلسات والإجراءات وتقديم التحديثات المهنية للعميل.</li>
                                </ul>
                                <ul class="bd-terms-list" t-if="bd_agreement_kind == 'arbitration'">
                                    <li>إدارة ملف التحكيم وإعداد الطلبات والمذكرات ذات الصلة.</li>
                                    <li>تمثيل العميل أمام هيئة التحكيم وفق قواعد التحكيم المعتمدة.</li>
                                    <li>تنسيق المستندات والشهود والخبراء ضمن النطاق المتفق عليه.</li>
                                </ul>
                            </td>
                            <td class="bd-en" lang="en" dir="ltr">
                                <div class="bd-pre" t-esc="doc.scope_of_work or doc.services_description or '-'"/>
                                <ul class="bd-terms-list" t-if="bd_agreement_kind == 'corporate'">
                                    <li>Provide legal advice on corporate and commercial matters.</li>
                                    <li>Review and draft commercial documents and agreements.</li>
                                    <li>Support relevant governmental procedures within the agreed scope.</li>
                                </ul>
                                <ul class="bd-terms-list" t-if="bd_agreement_kind == 'litigation'">
                                    <li>Assess the dispute and prepare required pleadings and submissions.</li>
                                    <li>Represent the client before courts and competent authorities under the mandate.</li>
                                    <li>Follow hearings and procedures and provide professional updates to the client.</li>
                                </ul>
                                <ul class="bd-terms-list" t-if="bd_agreement_kind == 'arbitration'">
                                    <li>Manage the arbitration file and prepare related requests and submissions.</li>
                                    <li>Represent the client before the arbitral tribunal under the applicable arbitration rules.</li>
                                    <li>Coordinate documents, witnesses, and experts within the agreed scope.</li>
                                </ul>
                            </td>
                        </tr>
                    </table>
                </div>
            </div>

            <div class="bd-section">
                <div class="bd-section-header">Fees &amp; Payment</div>
                <div class="bd-section-body">
                    <table class="bd-table">
                        <thead>
                            <tr>
                                <th>Service</th>
                                <th>Type</th>
                                <th>Qty</th>
                                <th>Unit Price</th>
                                <th>Discount</th>
                                <th>Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="doc.legal_fees_lines" t-as="line">
                                <td><t t-esc="line.service_name or line.description or '-'"/></td>
                                <td><span t-if="line.service_type" t-field="line.service_type"/><span t-if="not line.service_type">-</span></td>
                                <td class="bd-number"><t t-esc="'{:,.2f}'.format(line.quantity or 0.0)"/></td>
                                <td class="bd-number"><t t-esc="'{:,.3f}'.format(line.unit_price or 0.0)"/> <t t-esc="currency_name"/></td>
                                <td class="bd-number">
                                    <t t-if="line.discount_type == 'percent'"><t t-esc="'{:,.2f}'.format(line.discount or 0.0)"/>%</t>
                                    <t t-else=""><t t-esc="'{:,.3f}'.format(line.discount or 0.0)"/> <t t-esc="currency_name"/></t>
                                </td>
                                <td class="bd-number"><t t-esc="'{:,.3f}'.format(line.subtotal or line.amount or 0.0)"/> <t t-esc="currency_name"/></td>
                            </tr>
                            <tr t-if="not doc.legal_fees_lines">
                                <td>Legal Fees</td>
                                <td>-</td>
                                <td class="bd-number">1.00</td>
                                <td class="bd-number"><t t-esc="'{:,.3f}'.format(fee_total or 0.0)"/> <t t-esc="currency_name"/></td>
                                <td class="bd-number">0.00</td>
                                <td class="bd-number"><t t-esc="'{:,.3f}'.format(fee_total or 0.0)"/> <t t-esc="currency_name"/></td>
                            </tr>
                            <tr class="bd-total-row">
                                <td colspan="5">Total Legal Fees</td>
                                <td class="bd-number"><t t-esc="'{:,.3f}'.format(fee_total or 0.0)"/> <t t-esc="currency_name"/></td>
                            </tr>
                        </tbody>
                    </table>
                    <p t-if="doc.payment_terms"><strong>Payment Terms: </strong><t t-esc="doc.payment_terms"/></p>
                </div>
            </div>

            <div class="bd-section">
                <div class="bd-section-header">General Terms</div>
                <div class="bd-section-body">
                    <table class="bd-bilingual-table">
                        <tr>
                            <th class="bd-ar" lang="ar" dir="rtl">الأحكام العامة</th>
                            <th class="bd-en" lang="en" dir="ltr">General Terms</th>
                        </tr>
                        <tr>
                            <td class="bd-ar" lang="ar" dir="rtl">
                                <ol class="bd-terms-list">
                                    <li>تعد هذه الاتفاقية ونطاق العمل والملاحق جزءاً واحداً مكملًا لبعضه البعض.</li>
                                    <li>يلتزم العميل بتزويد المكتب بالمعلومات والمستندات الصحيحة والكاملة في الوقت المناسب.</li>
                                    <li>يلتزم المكتب ببذل العناية المهنية وفق القوانين واللوائح المعمول بها في دولة قطر.</li>
                                    <li>لا تشمل الأتعاب الرسوم الحكومية أو القضائية أو مصاريف الخبراء أو الترجمة ما لم يرد نص بخلاف ذلك.</li>
                                    <li>تظل المعلومات السرية محمية ولا يجوز الإفصاح عنها إلا بموافقة العميل أو متى كان الإفصاح مطلوباً قانوناً.</li>
                                </ol>
                            </td>
                            <td class="bd-en" lang="en" dir="ltr">
                                <ol class="bd-terms-list">
                                    <li>This Agreement, scope of work, and appendices form one integrated document.</li>
                                    <li>The client shall provide accurate and complete information and documents in a timely manner.</li>
                                    <li>The firm shall exercise professional due care in accordance with applicable laws and regulations in Qatar.</li>
                                    <li>Fees exclude governmental, court, expert, and translation expenses unless expressly stated otherwise.</li>
                                    <li>Confidential information remains protected and may be disclosed only with client consent or where legally required.</li>
                                </ol>
                            </td>
                        </tr>
                    </table>
                </div>
            </div>

            <t t-call="bd_pdf_builder.standard_signature_table"/>
        </t>
    </template>

    <data>
        <record id="action_corporate_service_agreement_pdf" model="ir.actions.report">
            <field name="name">Corporate Service Agreement</field>
            <field name="model">bd.engagement.letter</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">bd_pdf_builder.report_corporate_service_agreement_pdf</field>
            <field name="report_file">bd_pdf_builder.report_corporate_service_agreement_pdf</field>
            <field name="paperformat_id" ref="bd_pdf_builder.paperformat_bd_standard_pdf"/>
            <field name="binding_model_id" ref="qlk_management.model_bd_engagement_letter"/>
            <field name="binding_type">report</field>
            <field name="print_report_name">'Corporate Service Agreement - %s' % (object.display_name or object.id)</field>
        </record>

        <record id="action_litigation_service_agreement_pdf" model="ir.actions.report">
            <field name="name">Litigation Service Agreement</field>
            <field name="model">bd.engagement.letter</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">bd_pdf_builder.report_litigation_service_agreement_pdf</field>
            <field name="report_file">bd_pdf_builder.report_litigation_service_agreement_pdf</field>
            <field name="paperformat_id" ref="bd_pdf_builder.paperformat_bd_standard_pdf"/>
            <field name="binding_model_id" ref="qlk_management.model_bd_engagement_letter"/>
            <field name="binding_type">report</field>
            <field name="print_report_name">'Litigation Service Agreement - %s' % (object.display_name or object.id)</field>
        </record>

        <record id="action_arbitration_service_agreement_pdf" model="ir.actions.report">
            <field name="name">Arbitration Service Agreement</field>
            <field name="model">bd.engagement.letter</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">bd_pdf_builder.report_arbitration_service_agreement_pdf</field>
            <field name="report_file">bd_pdf_builder.report_arbitration_service_agreement_pdf</field>
            <field name="paperformat_id" ref="bd_pdf_builder.paperformat_bd_standard_pdf"/>
            <field name="binding_model_id" ref="qlk_management.model_bd_engagement_letter"/>
            <field name="binding_type">report</field>
            <field name="print_report_name">'Arbitration Service Agreement - %s' % (object.display_name or object.id)</field>
        </record>
    </data>
</odoo>
