<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="paperformat_engagement_letter_pdf" model="report.paperformat">
            <field name="name">Engagement Letter A4</field>
            <field name="default" eval="False"/>
            <field name="format">A4</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">28</field>
            <field name="margin_bottom">26</field>
            <field name="margin_left">10</field>
            <field name="margin_right">10</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">8</field>
            <field name="disable_shrinking" eval="True"/>
            <field name="dpi">110</field>
        </record>

        <record id="action_engagement_letter_pdf" model="ir.actions.report">
            <field name="name">Engagement Letter PDF</field>
            <field name="model">bd.engagement.letter</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">bd_pdf_builder.report_engagement_letter_pdf</field>
            <field name="report_file">bd_pdf_builder.report_engagement_letter_pdf</field>
            <field name="paperformat_id" ref="bd_pdf_builder.paperformat_engagement_letter_pdf"/>
            <field name="print_report_name">'Engagement Letter - %s' % (object.display_name or object.id)</field>
        </record>
    </data>
</odoo>
