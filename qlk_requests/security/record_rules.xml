<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="rule_qlk_internal_request_user" model="ir.rule">
            <field name="name">Requests User</field>
            <field name="model_id" ref="model_qlk_internal_request"/>
            <field name="domain_force">['|', '|', ('requested_by', '=', user.id), ('assigned_to', '=', user.id), ('assigned_user_ids', 'in', [user.id])]</field>
            <field name="groups" eval="[(6, 0, [ref('qlk_requests.group_request_user')])]"/>
        </record>
        <record id="rule_qlk_internal_request_manager" model="ir.rule">
            <field name="name">Requests Manager</field>
            <field name="model_id" ref="model_qlk_internal_request"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(6, 0, [ref('qlk_requests.group_request_manager')])]"/>
        </record>
        <record id="rule_qlk_internal_request_mp" model="ir.rule">
            <field name="name">Requests MP</field>
            <field name="model_id" ref="model_qlk_internal_request"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(6, 0, [ref('qlk_management.group_pre_litigation_manager')])]"/>
        </record>
    </data>
</odoo>
