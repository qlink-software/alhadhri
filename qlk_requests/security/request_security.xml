<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_qlk_request_manager" model="res.groups">
        <field name="name">Requests Manager</field>
    </record>

    <record id="rule_qlk_request_user_own_or_assigned" model="ir.rule">
        <field name="name">Requests: own or assigned</field>
        <field name="model_id" ref="model_qlk_internal_request"/>
        <field name="domain_force">['|', ('requested_by', '=', user.id), ('assigned_to', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_qlk_request_manager_all" model="ir.rule">
        <field name="name">Requests: manager all</field>
        <field name="model_id" ref="model_qlk_internal_request"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('qlk_requests.group_qlk_request_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
</odoo>
