<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_qlk_request_list" model="ir.ui.view">
        <field name="name">qlk.internal.request.list</field>
        <field name="model">qlk.internal.request</field>
        <field name="arch" type="xml">
            <list string="Requests" default_order="request_date desc">
                <field name="name"/>
                <field name="requested_by"/>
                <field name="assigned_to"/>
                <field name="employee_ids" widget="many2many_tags"/>
                <field name="engagement_id"/>
                <field name="case_id"/>
                <field name="receive_date"/>
                <field name="delivery_date"/>
                <field name="required_hours" widget="float_time" sum="Required Hours"/>
                <field name="hours_spent" widget="float_time" sum="Total Hours"/>
                <field name="request_date"/>
                <field name="priority" widget="badge"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_qlk_request_calendar" model="ir.ui.view">
        <field name="name">qlk.internal.request.calendar</field>
        <field name="model">qlk.internal.request</field>
        <field name="arch" type="xml">
            <calendar string="Requests Calendar"
                      date_start="request_date"
                      color="assigned_to"
                      mode="month"
                      quick_create="false"
                      event_open_popup="true">
                <field name="name"/>
                <field name="requested_by"/>
                <field name="assigned_to"/>
                <field name="employee_ids"/>
                <field name="engagement_id"/>
                <field name="case_id"/>
                <field name="receive_date"/>
                <field name="delivery_date"/>
                <field name="required_hours"/>
                <field name="hours_spent"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>

    <record id="view_qlk_request_kanban" model="ir.ui.view">
        <field name="name">qlk.internal.request.kanban</field>
        <field name="model">qlk.internal.request</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="requested_by"/>
                <field name="employee_ids"/>
                <field name="receive_date"/>
                <field name="delivery_date"/>
                <field name="required_hours"/>
                <field name="state"/>
                <field name="priority"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click o_kanban_record qlk_request_card qlk_request_state_#{record.state.raw_value or 'draft'}">
                            <div class="d-flex justify-content-between align-items-start gap-2">
                                <strong class="o_kanban_record_title"><field name="name"/></strong>
                                <span t-attf-class="badge rounded-pill qlk_request_badge qlk_request_badge_#{record.state.raw_value or 'draft'}">
                                    <field name="state"/>
                                </span>
                            </div>
                            <div class="text-muted mt-1">
                                <i class="fa fa-user-o me-1"/> <field name="requested_by"/>
                            </div>
                            <div class="qlk_request_meta mt-3">
                                <span><i class="fa fa-inbox me-1"/> <field name="receive_date" widget="datetime"/></span>
                                <span><i class="fa fa-paper-plane-o me-1"/> <field name="delivery_date" widget="datetime"/></span>
                                <span class="qlk_request_hours"><i class="fa fa-clock-o me-1"/> <field name="required_hours" widget="float_time"/></span>
                            </div>
                            <div class="mt-3">
                                <field name="employee_ids" widget="many2many_tags"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_qlk_request_form" model="ir.ui.view">
        <field name="name">qlk.internal.request.form</field>
        <field name="model">qlk.internal.request</field>
        <field name="arch" type="xml">
            <form string="Request">
                <header>
                    <button name="action_start" type="object" string="Start" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_complete" type="object" string="Complete" class="btn-success"
                            invisible="state != 'in_progress'"/>
                    <button name="action_cancel" type="object" string="Cancel" class="btn-secondary"
                            invisible="state == 'cancelled'"/>
                    <button name="action_reset_to_draft" type="object" string="Reset to Draft"
                            invisible="state == 'draft'"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="اسم الطلب"/>
                        </h1>
                    </div>
                    <group string="Request Status / حالة الطلب">
                        <field name="state" widget="statusbar" statusbar_visible="draft,in_progress,done,cancelled"/>
                    </group>
                    <group>
                        <group string="Request Details / بيانات الطلب">
                            <field name="name"/>
                            <field name="requested_by"/>
                            <field name="state" readonly="1" widget="badge"/>
                            <field name="request_date"/>
                            <field name="engagement_id"/>
                            <field name="case_id"/>
                        </group>
                        <group string="Employees &amp; Schedule / الموظفون والمواعيد">
                            <field name="employee_ids" widget="many2many_tags"/>
                            <field name="assigned_to"/>
                            <field name="receive_date"/>
                            <field name="delivery_date"/>
                            <field name="required_hours" widget="float_time" options="{'displaySeconds': True}"/>
                            <field name="priority"/>
                            <field name="hours_spent" widget="float_time" options="{'displaySeconds': True}"/>
                            <field name="completed_by" readonly="1"/>
                            <field name="done_date" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description / الوصف">
                            <field name="description" nolabel="1" placeholder="وصف الطلب"/>
                        </page>
                        <page string="Completion Notes / ملاحظات الإنجاز">
                            <field name="completion_notes" nolabel="1"/>
                        </page>
                        <page string="Attachments / المرفقات">
                            <field name="attachment_ids" nolabel="1" context="{'default_res_model': 'qlk.internal.request', 'default_res_id': id}">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="datas" string="Preview / Download" filename="name" widget="binary"/>
                                    <field name="create_date" string="Upload Date" readonly="1"/>
                                    <field name="create_uid" string="Uploaded By" readonly="1"/>
                                    <field name="mimetype" readonly="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_qlk_request_search" model="ir.ui.view">
        <field name="name">qlk.internal.request.search</field>
        <field name="model">qlk.internal.request</field>
        <field name="arch" type="xml">
            <search string="Requests">
                <field name="name"/>
                <field name="requested_by"/>
                <field name="assigned_to"/>
                <field name="employee_ids"/>
                <field name="engagement_id"/>
                <field name="case_id"/>
                <field name="request_date"/>
                <field name="receive_date"/>
                <field name="delivery_date"/>
                <field name="required_hours"/>
                <field name="hours_spent"/>
                <field name="state"/>
                <filter name="filter_my_requests" string="My Requests" domain="[('requested_by', '=', uid)]"/>
                <filter name="filter_assigned_to_me" string="Assigned To Me" domain="['|', ('assigned_to', '=', uid), ('assigned_user_ids', 'in', [uid])]"/>
                <filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="filter_in_progress" string="In Progress" domain="[('state', '=', 'in_progress')]"/>
                <filter name="filter_done" string="Done" domain="[('state', '=', 'done')]"/>
                <filter name="filter_delayed" string="Delayed" domain="[('delivery_date', '&lt;', context_today().strftime('%Y-%m-%d 23:59:59')), ('state', 'not in', ['done', 'cancelled'])]"/>
                <filter name="filter_today" string="Today" domain="[('request_date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_requested_by" string="Requested By" context="{'group_by': 'requested_by'}"/>
                    <filter name="group_assigned_to" string="Assigned To" context="{'group_by': 'assigned_to'}"/>
                    <filter name="group_engagement" string="Engagement" context="{'group_by': 'engagement_id'}"/>
                    <filter name="group_case" string="Case" context="{'group_by': 'case_id'}"/>
                    <filter name="group_date" string="Date" context="{'group_by': 'request_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_qlk_request" model="ir.actions.act_window">
        <field name="name">Requests</field>
        <field name="res_model">qlk.internal.request</field>
        <field name="view_mode">kanban,list,calendar,form</field>
        <field name="context">{}</field>
    </record>

    <record id="action_qlk_request_list" model="ir.actions.act_window">
        <field name="name">Requests</field>
        <field name="res_model">qlk.internal.request</field>
        <field name="view_mode">list,kanban,calendar,form</field>
        <field name="context">{}</field>
    </record>

    <record id="action_qlk_request_my" model="ir.actions.act_window">
        <field name="name">My Requests</field>
        <field name="res_model">qlk.internal.request</field>
        <field name="view_mode">kanban,list,calendar,form</field>
        <field name="domain">[('requested_by', '=', uid)]</field>
        <field name="context">{'search_default_filter_my_requests': 1}</field>
    </record>

    <record id="action_qlk_request_assigned_to_me" model="ir.actions.act_window">
        <field name="name">Assigned To Me</field>
        <field name="res_model">qlk.internal.request</field>
        <field name="view_mode">kanban,list,calendar,form</field>
        <field name="domain">['|', ('assigned_to', '=', uid), ('assigned_user_ids', 'in', [uid])]</field>
        <field name="context">{'search_default_filter_assigned_to_me': 1}</field>
    </record>

    <record id="action_qlk_request_all" model="ir.actions.act_window">
        <field name="name">All Requests</field>
        <field name="res_model">qlk.internal.request</field>
        <field name="view_mode">kanban,list,calendar,form</field>
        <field name="context">{'search_default_group_state': 1}</field>
    </record>
</odoo>
