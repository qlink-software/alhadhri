<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_qlk_request_list" model="ir.ui.view">
        <field name="name">qlk.internal.request.list</field>
        <field name="model">qlk.internal.request</field>
        <field name="arch" type="xml">
            <list string="Requests" default_order="request_date desc">
                <field name="name"/>
                <field name="requested_by"/>
                <field name="assigned_to"/>
                <field name="engagement_id"/>
                <field name="case_id"/>
                <field name="hours_spent" widget="float_time" sum="Total Hours"/>
                <field name="request_date"/>
                <field name="priority" widget="badge"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_qlk_request_calendar" model="ir.ui.view">
        <field name="name">qlk.internal.request.calendar</field>
        <field name="model">qlk.internal.request</field>
        <field name="arch" type="xml">
            <calendar string="Requests Calendar"
                      date_start="request_date"
                      color="assigned_to"
                      mode="month"
                      quick_create="false"
                      event_open_popup="true">
                <field name="name"/>
                <field name="requested_by"/>
                <field name="assigned_to"/>
                <field name="engagement_id"/>
                <field name="case_id"/>
                <field name="hours_spent"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>

    <record id="view_qlk_request_form" model="ir.ui.view">
        <field name="name">qlk.internal.request.form</field>
        <field name="model">qlk.internal.request</field>
        <field name="arch" type="xml">
            <form string="Request">
                <header>
                    <button name="action_submit" type="object" string="Submit" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_start" type="object" string="Start" class="btn-primary"
                            invisible="state != 'submitted'"/>
                    <button name="action_complete" type="object" string="Complete" class="btn-success"
                            invisible="state != 'in_progress'"/>
                    <button name="action_cancel" type="object" string="Cancel" class="btn-secondary"
                            invisible="state == 'cancelled'"/>
                    <button name="action_reset_to_draft" type="object" string="Reset to Draft"
                            invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,in_progress,done,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="اسم الطلب"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="requested_by"/>
                            <field name="assigned_to"/>
                            <field name="request_date"/>
                            <field name="engagement_id"/>
                            <field name="case_id"/>
                        </group>
                        <group>
                            <field name="priority"/>
                            <field name="hours_spent" widget="float_time" options="{'displaySeconds': True}"/>
                            <field name="state" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description" nolabel="1" placeholder="وصف الطلب"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_qlk_request_search" model="ir.ui.view">
        <field name="name">qlk.internal.request.search</field>
        <field name="model">qlk.internal.request</field>
        <field name="arch" type="xml">
            <search string="Requests">
                <field name="name"/>
                <field name="requested_by"/>
                <field name="assigned_to"/>
                <field name="engagement_id"/>
                <field name="case_id"/>
                <field name="request_date"/>
                <field name="hours_spent"/>
                <field name="state"/>
                <filter name="filter_my_requests" string="My Requests" domain="[('requested_by', '=', uid)]"/>
                <filter name="filter_assigned_to_me" string="Assigned To Me" domain="[('assigned_to', '=', uid)]"/>
                <filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="filter_submitted" string="Submitted" domain="[('state', '=', 'submitted')]"/>
                <filter name="filter_in_progress" string="In Progress" domain="[('state', '=', 'in_progress')]"/>
                <filter name="filter_done" string="Done" domain="[('state', '=', 'done')]"/>
                <filter name="filter_today" string="Today" domain="[('request_date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_requested_by" string="Requested By" context="{'group_by': 'requested_by'}"/>
                    <filter name="group_assigned_to" string="Assigned To" context="{'group_by': 'assigned_to'}"/>
                    <filter name="group_engagement" string="Engagement" context="{'group_by': 'engagement_id'}"/>
                    <filter name="group_case" string="Case" context="{'group_by': 'case_id'}"/>
                    <filter name="group_date" string="Date" context="{'group_by': 'request_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_qlk_request" model="ir.actions.act_window">
        <field name="name">Requests</field>
        <field name="res_model">qlk.internal.request</field>
        <field name="view_mode">list,calendar,form</field>
        <field name="context">{}</field>
    </record>

    <record id="action_qlk_request_my" model="ir.actions.act_window">
        <field name="name">My Requests</field>
        <field name="res_model">qlk.internal.request</field>
        <field name="view_mode">list,calendar,form</field>
        <field name="domain">[('requested_by', '=', uid)]</field>
        <field name="context">{'search_default_filter_my_requests': 1}</field>
    </record>

    <record id="action_qlk_request_assigned_to_me" model="ir.actions.act_window">
        <field name="name">Assigned To Me</field>
        <field name="res_model">qlk.internal.request</field>
        <field name="view_mode">list,calendar,form</field>
        <field name="domain">[('assigned_to', '=', uid)]</field>
        <field name="context">{'search_default_filter_assigned_to_me': 1}</field>
    </record>

    <record id="action_qlk_request_all" model="ir.actions.act_window">
        <field name="name">All Requests</field>
        <field name="res_model">qlk.internal.request</field>
        <field name="view_mode">list,calendar,form</field>
        <field name="context">{'search_default_group_state': 1}</field>
    </record>
</odoo>
