<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="qlk_management_dynamicanalysise_category" model="ir.module.category">
            <field name="name">Dynamic Analysis Category</field>
            <field name="sequence" eval="70"/>
        </record>
        <record id="group_qlk_dynamic_analysis_dashboard_user" model="res.groups">
            <field name="name">Dynamic Analysis Dashboard User</field>
            <field name="category_id" ref="qlk_dynamic_analysis_dashboard.qlk_management_dynamicanalysise_category"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>
        <record id="group_qlk_dynamic_analysis_dashboard_manager" model="res.groups">
            <field name="name">Dynamic Analysis Dashboard Manager</field>
            <field name="category_id" ref="qlk_dynamic_analysis_dashboard.qlk_management_dynamicanalysise_category"/>
            <field name="implied_ids" eval="[(4, ref('qlk_dynamic_analysis_dashboard.group_qlk_dynamic_analysis_dashboard_user'))]"/>
        </record>
    </data>
</odoo>
