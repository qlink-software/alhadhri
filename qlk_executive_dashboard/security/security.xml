<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="qlk_management_executive_category" model="ir.module.category">
            <field name="name">Executive Category</field>
            <field name="sequence" eval="75"/>
        </record>
        <record id="group_qlk_executive_dashboard_user" model="res.groups">
            <field name="name">Executive Dashboard User</field>
            <field name="category_id" ref="qlk_executive_dashboard.qlk_management_executive_category"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_qlk_executive_dashboard_manager" model="res.groups">
            <field name="name">Executive Dashboard Manager</field>
            <field name="category_id" ref="qlk_executive_dashboard.qlk_management_executive_category"/>
            <field name="implied_ids" eval="[(4, ref('qlk_executive_dashboard.group_qlk_executive_dashboard_user'))]"/>
        </record>
    </data>
</odoo>
