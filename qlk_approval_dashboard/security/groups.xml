<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="qlk_management_approval_category" model="ir.module.category">
            <field name="name">Approvals Category</field>
            <field name="sequence" eval="50"/>
        </record>
        <record id="group_qlk_approval_dashboard_user" model="res.groups">
            <field name="name">Approval Dashboard User</field>
            <field name="category_id" ref="qlk_approval_dashboard.qlk_management_approval_category"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_qlk_approval_dashboard_manager" model="res.groups">
            <field name="name">Approval Dashboard Manager</field>
            <field name="category_id" ref="qlk_approval_dashboard.qlk_management_approval_category"/>
            <field name="implied_ids" eval="[(4, ref('qlk_approval_dashboard.group_qlk_approval_dashboard_user'))]"/>
        </record>
    </data>
</odoo>
