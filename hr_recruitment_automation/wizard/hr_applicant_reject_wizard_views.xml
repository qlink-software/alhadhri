<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_applicant_offer_reject_wizard_form" model="ir.ui.view">
        <field name="name">hr.applicant.offer.reject.wizard.form</field>
        <field name="model">hr.applicant.offer.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Reject Job Offer">
                <group>
                    <field name="applicant_id" readonly="1"/>
                    <field name="reason"/>
                </group>
                <footer>
                    <button name="action_confirm_reject" type="object" string="Reject" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
