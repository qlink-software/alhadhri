<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_biometric_sync" model="ir.cron">
            <field name="name">Biometric Attendance Sync</field>
            <field name="model_id" ref="hr_recruitment_automation.model_hr_biometric_device"/>
            <field name="state">code</field>
            <field name="code">model.cron_sync_all_devices()</field>
            <field name="interval_number">10</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
        </record>

        <record id="ir_cron_weekly_hours_reminder" model="ir.cron">
            <field name="name">Weekly Hours Reminder To MP</field>
            <field name="model_id" ref="hr.model_hr_employee"/>
            <field name="state">code</field>
            <field name="code">model.cron_send_weekly_hours_reminder()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>

        <record id="ir_cron_resignation_deactivation" model="ir.cron">
            <field name="name">Resignation Notice Period Deactivation</field>
            <field name="model_id" ref="hr.model_hr_employee"/>
            <field name="state">code</field>
            <field name="code">model.cron_deactivate_after_notice_period()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>
