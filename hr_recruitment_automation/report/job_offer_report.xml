<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="paperformat_job_offer" model="report.paperformat">
        <field name="name">Job Offer A4</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">20</field>
        <field name="margin_bottom">18</field>
        <field name="margin_left">12</field>
        <field name="margin_right">12</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">12</field>
        <field name="dpi">96</field>
    </record>

    <record id="action_report_job_offer" model="ir.actions.report">
        <field name="name">Job Offer</field>
        <field name="model">hr.applicant</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">hr_recruitment_automation.job_offer_report</field>
        <field name="report_file">hr_recruitment_automation.job_offer_report</field>
        <field name="binding_model_id" ref="hr_recruitment.model_hr_applicant"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="hr_recruitment_automation.paperformat_job_offer"/>
        <field name="print_report_name">'Job Offer - %s' % (object.candidate_name or object.partner_name or 'Candidate')</field>
    </record>
</odoo>
