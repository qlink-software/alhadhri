<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_contract_form_recruitment_automation" model="ir.ui.view">
        <field name="name">hr.contract.form.recruitment.automation</field>
        <field name="model">hr.contract</field>
        <field name="inherit_id" ref="hr_contract.hr_contract_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='information']/group[@name='salary_info']" position="inside">
                <group string="Allowance Details">
                    <field name="housing_allowance" required="1"/>
                    <field name="transportation_allowance" required="1"/>
                    <field name="phone_allowance" required="1"/>
                    <field name="other_allowance" required="1"/>
                    <field name="salary_type" required="1"/>
                    <field name="payroll_start_date" required="1"/>
                    <field name="bank_name" required="1"/>
                    <field name="bank_account_number" required="1"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
