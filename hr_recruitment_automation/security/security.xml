<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="module_category_hr_recruitment_automation" model="ir.module.category">
            <field name="name">HR Recruitment Automation</field>
            <field name="sequence">48</field>
        </record>

        <record id="group_recruitment_officer" model="res.groups">
            <field name="name">Recruitment Officer (Automation)</field>
            <field name="category_id" ref="hr_recruitment_automation.module_category_hr_recruitment_automation"/>
            <field name="implied_ids" eval="[(4, ref('hr_recruitment.group_hr_recruitment_user'))]"/>
        </record>

        <record id="group_office_manager" model="res.groups">
            <field name="name">Office Manager (Automation)</field>
            <field name="category_id" ref="hr_recruitment_automation.module_category_hr_recruitment_automation"/>
            <field name="implied_ids" eval="[(4, ref('hr_recruitment.group_hr_recruitment_user'))]"/>
        </record>

        <record id="group_managing_partner" model="res.groups">
            <field name="name">Managing Partner (Automation)</field>
            <field name="category_id" ref="hr_recruitment_automation.module_category_hr_recruitment_automation"/>
            <field name="implied_ids" eval="[(4, ref('hr_recruitment.group_hr_recruitment_user'))]"/>
        </record>

        <!-- هذه القاعدة تمنح الـ Managing Partner حق اعتماد/رفض عروض التوظيف. -->
        <record id="hr_applicant_rule_managing_partner" model="ir.rule">
            <field name="name">Applicant access for Managing Partner</field>
            <field name="model_id" ref="hr_recruitment.model_hr_applicant"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
            <field name="groups" eval="[(4, ref('hr_recruitment_automation.group_managing_partner'))]"/>
        </record>

        <!-- السماح لمستخدم البوابة بقراءة حزمة مستنداته فقط عند الحاجة داخل الواجهة. -->
        <record id="document_package_portal_rule" model="ir.rule">
            <field name="name">Document package portal own access</field>
            <field name="model_id" ref="hr_recruitment_automation.model_hr_recruitment_document_package"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        </record>
    </data>
</odoo>
